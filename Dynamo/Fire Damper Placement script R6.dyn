    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import os\r\nimport datetime\r\nimport clr\r\n\r\n# -------------------------------\r\n# SYSTEM / DESKTOP PATH (IRONPYTHON SAFE)\r\n# -------------------------------\r\n\r\nclr.AddReference(\"System\")\r\nimport System\r\n\r\ndesktop_dir = System.Environment.GetFolderPath(\r\n    System.Environment.SpecialFolder.Desktop\r\n)\r\n\r\nwarnings_dir = os.path.join(desktop_dir, \"DAR_WARNINGS\")\r\nif not os.path.exists(warnings_dir):\r\n    os.makedirs(warnings_dir)\r\n\r\n# -------------------------------\r\n# REVIT / DYNAMO IMPORTS\r\n# -------------------------------\r\n\r\nclr.AddReference(\"RevitServices\")\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\nclr.AddReference(\"RevitAPI\")\r\nfrom Autodesk.Revit.DB import *\r\n\r\nclr.AddReference(\"RevitNodes\")\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# -------------------------------\r\n# INPUTS\r\n# -------------------------------\r\n\r\ntitle = IN[0]\r\nelements = IN[1]\r\nnames = IN[2]\r\nwarnings = IN[3]\r\n\r\n# Halt execution and prevent file creation if any of the three are empty or None\r\nif not elements or not names or not warnings:\r\n    raise Exception(\"Elements, names, and warnings cannot be empty. No file created.\")\r\n\r\nuse_names = len(names) == len(elements)\r\n\r\n# -------------------------------\r\n# SAFE LEVEL RESOLUTION\r\n# -------------------------------\r\ndef get_level_name_safe(elem):\r\n    try:\r\n        # Direct properties\r\n        if hasattr(elem, \"LevelId\"):\r\n            lvl = doc.GetElement(elem.LevelId)\r\n            if lvl: return lvl.Name\r\n\r\n        if hasattr(elem, \"Level\") and elem.Level:\r\n            return elem.Level.Name\r\n\r\n        if hasattr(elem, \"GenLevel\") and elem.GenLevel:\r\n            return elem.GenLevel.Name\r\n\r\n        # Common parameters fallback\r\n        for bip in [\r\n            BuiltInParameter.INSTANCE_REFERENCE_LEVEL_PARAM,\r\n            BuiltInParameter.SCHEDULE_LEVEL_PARAM,\r\n            BuiltInParameter.INSTANCE_SCHEDULE_ONLY_LEVEL_PARAM,\r\n            BuiltInParameter.RBS_START_LEVEL_PARAM\r\n        ]:\r\n            try:\r\n                p = elem.get_Parameter(bip)\r\n                if p:\r\n                    lvl = doc.GetElement(p.AsElementId())\r\n                    if lvl: return lvl.Name\r\n            except:\r\n                pass\r\n    except:\r\n        pass\r\n\r\n    return \"Unknown\"\r\n\r\n# -------------------------------\r\n# BUILD SORTABLE DATA\r\n# -------------------------------\r\n\r\nsortable = []\r\n\r\nfor idx, dyn_elem in enumerate(elements):\r\n    revit_elem = None\r\n    level_name = \"Unknown\"\r\n    elevation = float(\"inf\")\r\n\r\n    try:\r\n        revit_elem = UnwrapElement(dyn_elem)\r\n        level_name = get_level_name_safe(revit_elem)\r\n\r\n        if level_name != \"Unknown\":\r\n            lvl = next(\r\n                (l for l in FilteredElementCollector(doc).OfClass(Level)\r\n                 if l.Name == level_name),\r\n                None\r\n            )\r\n            if lvl:\r\n                elevation = lvl.Elevation\r\n    except:\r\n        pass\r\n\r\n    sortable.append({\r\n        \"index\": idx,\r\n        \"element\": revit_elem,\r\n        \"level_name\": level_name,\r\n        \"elevation\": elevation\r\n    })\r\n\r\n# -------------------------------\r\n# SORT (BY LEVEL, UNKNOWN LAST)\r\n# -------------------------------\r\n\r\nsortable_sorted = sorted(\r\n    sortable,\r\n    key=lambda x: (x[\"elevation\"], x[\"index\"])\r\n)\r\n\r\n# -------------------------------\r\n# PROJECT NAME\r\n# -------------------------------\r\n\r\nproject_name = (\r\n    os.path.splitext(os.path.basename(doc.PathName))[0]\r\n    if doc.PathName else \"Unsaved_Project\"\r\n)\r\n\r\n# -------------------------------\r\n# BUILD TXT CONTENT\r\n# -------------------------------\r\n\r\nlines = []\r\nnow_str = datetime.datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\r\n\r\nlines.append(\"PROJECT|{}\".format(project_name))\r\nlines.append(\"TITLE|{}\".format(title))\r\nlines.append(\"GENERATED_ON|{}\".format(now_str))\r\nlines.append(\"\")\r\n\r\nfor i, item in enumerate(sortable_sorted):\r\n    idx = item[\"index\"]\r\n    elem = item[\"element\"]\r\n\r\n    elem_id = \"\"\r\n    elem_name = \"\"\r\n\r\n    if elem:\r\n        try:\r\n            elem_id = elem.Id.IntegerValue\r\n            elem_name = elem.Name\r\n        except:\r\n            pass\r\n\r\n    if use_names:\r\n        elem_name = names[idx]\r\n\r\n    lines.append(\r\n        \"ROW|{}|{}|{}|{}|{}\".format(\r\n            i + 1,\r\n            item[\"level_name\"],\r\n            elem_id,\r\n            elem_name,\r\n            warnings[idx]\r\n        )\r\n    )\r\n\r\n# -------------------------------\r\n# WRITE FILE\r\n# -------------------------------\r\n\r\ntimestamp = datetime.datetime.now().strftime(\"%Y%m%d_%H%M%S\")\r\nfile_name = \"{}_DAR_Warnings_{}.txt\".format(project_name, timestamp)\r\nfile_path = os.path.join(warnings_dir, file_name)\r\n\r\nwith open(file_path, \"w\") as f:\r\n    f.write(\"\\n\".join(lines))\r\n\r\n# -------------------------------\r\n# OUTPUT\r\n# -------------------------------\r\n\r\nOUT = file_path",
