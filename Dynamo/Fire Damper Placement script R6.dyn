    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "NodeType": "CodeBlockNode",
      "Code": "CAT_==\"Wall\";",
      "Id": "cfe180b3a3814004ac121e3064fa2d94",
      "Inputs": [
        {
          "Id": "86d2b60e16b149de92c9dfbb45a30eeb",
          "Name": "CAT_",
