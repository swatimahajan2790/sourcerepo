    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\n\r\n# Data inputs\r\nlist_a = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\nlist_b = IN[1] if isinstance(IN[1], list) else [IN[1]]\r\n\r\nout_list = []\r\n\r\n# Check if each ID in list_a exists in list_b\r\nfor item in list_a:\r\n    if item in list_b:\r\n        out_list.append(True)\r\n    else:\r\n        out_list.append(False)\r\n\r\nOUT = out_list",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "a009b4f418974e78be8200746205c47f",
      "Inputs": [
        {
          "Id": "23c34fde665e4f79a26028589ef4f568",
