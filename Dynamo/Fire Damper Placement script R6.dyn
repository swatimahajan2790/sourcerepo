    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "NodeType": "CodeBlockNode",
      "Code": "[\"Electrical Services\",\"Mechanical Services\",\"MEP\",\"Technical/ MEP Rooms\"];",
      "Id": "aba2f8960ebc4f6fafe136bc842013c2",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "66d079d779e247ca8d389958ad73ff71",
          "Name": "",
          "Description": "Value of expression at line 1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\nimport sys\r\n\r\n# Import Dynamo Geometry for safe point creation\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript import Geometry as dg\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.DB.Mechanical import *\r\n\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n\r\n# --- METRIC TOLERANCES ---\r\nMIN_DUCT_LEN_FT = 250.0 / 304.8 \r\nMAX_DAMPER_DIST_FT = 500.0 / 304.8 \r\nOFFSET_DIST_FT = 100.0 / 304.8 # Exact 200mm distance\r\nFEET_TO_MM = 304.8\r\n\r\ndef safe_wrap(elem):\r\n    \"\"\"Safely wraps a Revit element for Dynamo, catching InvalidObjectExceptions.\"\"\"\r\n    if elem is None: return None\r\n    try:\r\n        return elem.ToDSType(True)\r\n    except:\r\n        try: return \"Unwrappable Element ID: \" + str(elem.Id.IntegerValue)\r\n        except: return \"Invalid Internal Element\"\r\n\r\ndef is_fire_damper(element):\r\n    \"\"\"Helper to check if an element is a Fire Damper based on Family Name.\"\"\"\r\n    if not isinstance(element, FamilyInstance): \r\n        return False\r\n        \r\n    if element.Category and element.Category.Id.IntegerValue == int(BuiltInCategory.OST_DuctAccessory):\r\n        try:\r\n            fam_name = element.Symbol.FamilyName.lower()\r\n            if \"fire\" in fam_name and \"damper\" in fam_name:\r\n                return True\r\n        except: pass\r\n    return False\r\n\r\ndef check_duct_for_damper(duct):\r\n    \"\"\"Helper to check all elements physically connected to the duct for a Fire Damper.\"\"\"\r\n    cm = duct.ConnectorManager\r\n    for conn in cm.Connectors:\r\n        if conn.IsConnected:\r\n            for ref in conn.AllRefs:\r\n                neighbor = ref.Owner\r\n                if neighbor.Id == duct.Id: continue\r\n                if isinstance(neighbor, MechanicalSystem): continue\r\n                \r\n                if neighbor.IsValidObject and is_fire_damper(neighbor):\r\n                    return True\r\n    return False\r\n\r\ndef get_full_chain(terminal):\r\n    chain = [safe_wrap(terminal)]\r\n    current = terminal\r\n    prev_id = terminal.Id\r\n    \r\n    # Traverse the system\r\n    for _ in range(30): \r\n        next_elem = None\r\n        \r\n        if hasattr(current, \"ConnectorManager\"):\r\n            cm = current.ConnectorManager\r\n        elif hasattr(current, \"MEPModel\") and current.MEPModel:\r\n            cm = current.MEPModel.ConnectorManager\r\n        else:\r\n            break\r\n\r\n        if not cm: break\r\n\r\n        for conn in cm.Connectors:\r\n            if not conn.IsConnected: continue\r\n            \r\n            for link in conn.AllRefs:\r\n                neighbor = link.Owner\r\n                \r\n                if neighbor.Id != current.Id and neighbor.Id != prev_id and not isinstance(neighbor, MechanicalSystem):\r\n                    if neighbor.IsValidObject:\r\n                        next_elem = neighbor\r\n                        break\r\n            if next_elem: break\r\n        \r\n        if next_elem:\r\n            # --- CONDITION 1: IS IT A TEE? ---\r\n            if isinstance(next_elem, FamilyInstance) and hasattr(next_elem, \"MEPModel\") and next_elem.MEPModel:\r\n                if hasattr(next_elem.MEPModel, \"PartType\"):\r\n                    if next_elem.MEPModel.PartType == PartType.Tee:\r\n                        return \"Tee found before duct\"\r\n            \r\n            # --- CONDITION 2: IS IT ALREADY A DAMPER RIGHT OFF THE FITTING? ---\r\n            if is_fire_damper(next_elem):\r\n                return \"Fire damper is already placed\"\r\n                \r\n            # Safely wrap before appending\r\n            chain.append(safe_wrap(next_elem))\r\n            \r\n            # --- CONDITION 3: IS IT A SUITABLE DUCT? ---\r\n            if isinstance(next_elem, Duct):\r\n                param = next_elem.get_Parameter(BuiltInParameter.CURVE_ELEM_LENGTH)\r\n                if param:\r\n                    length_ft = param.AsDouble()\r\n                    \r\n                    if length_ft >= MIN_DUCT_LEN_FT:\r\n                        if check_duct_for_damper(next_elem):\r\n                            if length_ft <= MAX_DAMPER_DIST_FT:\r\n                                return \"Fire damper is already placed\"\r\n                                \r\n                        # --- NEW: CALCULATE THE 200mm INSERTION POINT ---\r\n                        damper_pt = None\r\n                        try:\r\n                            curve = next_elem.Location.Curve\r\n                            p0 = curve.GetEndPoint(0)\r\n                            p1 = curve.GetEndPoint(1)\r\n                            \r\n                            # Find the origin of the fitting we just came from\r\n                            prev_origin = None\r\n                            try:\r\n                                if current.Location and hasattr(current.Location, \"Point\"):\r\n                                    prev_origin = current.Location.Point\r\n                                else:\r\n                                    prev_origin = current.GetTransform().Origin\r\n                            except:\r\n                                prev_origin = p0\r\n                                \r\n                            # Compare distances to find which end of the duct connects to the fitting\r\n                            if prev_origin.DistanceTo(p0) < prev_origin.DistanceTo(p1):\r\n                                start_pt = p0\r\n                                end_pt = p1\r\n                            else:\r\n                                start_pt = p1\r\n                                end_pt = p0\r\n                                \r\n                            # Generate Vector and calculate 200mm offset\r\n                            direction = end_pt.Subtract(start_pt).Normalize()\r\n                            offset_xyz = start_pt.Add(direction.Multiply(OFFSET_DIST_FT))\r\n                            \r\n                            # Safely convert to a Dynamo Workspace Point (Metric)\r\n                            damper_pt = dg.Point.ByCoordinates(offset_xyz.X * FEET_TO_MM, offset_xyz.Y * FEET_TO_MM, offset_xyz.Z * FEET_TO_MM)\r\n                        except:\r\n                            pass\r\n                            \r\n                        # Return both the chain and the placement point\r\n                        return {\"Chain\": chain, \"DamperPoint\": damper_pt}\r\n\r\n            prev_id = current.Id\r\n            current = next_elem\r\n        else:\r\n            break\r\n            \r\n    return \"No suitable duct > 250mm found\"\r\n\r\n# --- Input/Output Logic ---\r\ninput_items = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\n\r\n# Initialize our dictionaries. Success now holds the 200mm insertion point.\r\nsuccess_dict = {\"AirTerminals\": [], \"Chains\": [], \"DamperPoints\": []}\r\nwarning_dict = {\"AirTerminals\": [], \"Warnings\": []}\r\n\r\nfor item in input_items:\r\n    try:\r\n        terminal_obj = UnwrapElement(item)\r\n        \r\n        if terminal_obj and terminal_obj.IsValidObject:\r\n            result = get_full_chain(terminal_obj)\r\n            \r\n            # Check if it successfully returned our dictionary\r\n            if isinstance(result, dict):\r\n                success_dict[\"AirTerminals\"].append(safe_wrap(terminal_obj))\r\n                success_dict[\"Chains\"].append(result[\"Chain\"])\r\n                success_dict[\"DamperPoints\"].append(result[\"DamperPoint\"])\r\n            else:\r\n                # 2. ALREADY PLACED: Ignore entirely\r\n                if result == \"Fire damper is already placed\":\r\n                    continue\r\n                    \r\n                # 3. WARNING: Add to the parallel Warning lists\r\n                warning_dict[\"AirTerminals\"].append(safe_wrap(terminal_obj))\r\n                warning_dict[\"Warnings\"].append(result)\r\n        else:\r\n            warning_dict[\"AirTerminals\"].append(\"Null/Deleted Input\")\r\n            warning_dict[\"Warnings\"].append(\"Invalid or Null Input Element\")\r\n            \r\n    except Exception as e:\r\n        warning_dict[\"AirTerminals\"].append(\"Error\")\r\n        warning_dict[\"Warnings\"].append(\"PYTHON ERROR: \" + str(e))\r\n\r\n# Output parallel dictionaries\r\n# OUT[0] = Success Dictionary\r\n# OUT[1] = Warning Dictionary\r\nOUT = [success_dict, warning_dict]",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "4a65db614531421a8b9956555935aa36",
      "Inputs": [
        {
          "Id": "a1ad106fd5c84faf8cab2fe7102e2dc3",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "350a5aca366348d0a38f794523439445",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
