      "NodeType": "PythonScriptNode",
      "Code": "# -*- coding: utf-8 -*-\r\nimport clr\r\nimport math\r\n\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript import Geometry as dg\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.DB.Mechanical import Duct\r\n\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n\r\n# 200mm each way (400mm total centerline for Air Terminals)\r\nEXT_LEN_FT = 200.0 / 304.8\r\n\r\ndef get_offset_lines(item):\r\n    \"\"\"Processes Ducts and Air Terminals and returns 9 lines (Center + 8 Perimeter).\"\"\"\r\n    if item is None: return None\r\n    \r\n    # Pass metadata strings or numbers through untouched\r\n    if isinstance(item, (str, int, float, bool)):\r\n        return item\r\n        \r\n    try:\r\n        elem = UnwrapElement(item)\r\n        if not elem or not hasattr(elem, \"IsValidObject\") or not elem.IsValidObject:\r\n            return item\r\n\r\n        # --- STEP 1: EXTRACT CURVE AND DIMENSIONS ---\r\n        loc_curve = None\r\n        shape = None\r\n        width = 0.0\r\n        height = 0.0\r\n        radius = 0.0\r\n\r\n        # SCENARIO A: DUCT\r\n        if isinstance(elem, Duct):\r\n            loc_curve = elem.Location.Curve\r\n            shape = elem.DuctType.Shape\r\n            if shape == ConnectorProfileType.Round:\r\n                radius = elem.Diameter / 2.0\r\n            else:\r\n                width = elem.Width\r\n                height = elem.Height\r\n\r\n        # SCENARIO B: AIR TERMINAL\r\n        elif isinstance(elem, FamilyInstance) or (elem.Category and elem.Category.Id.IntegerValue == int(BuiltInCategory.OST_DuctTerminal)):\r\n            \r\n            # 1. Ironclad Origin\r\n            origin = None\r\n            try:\r\n                if elem.Location and hasattr(elem.Location, \"Point\"): origin = elem.Location.Point\r\n            except: pass\r\n            \r\n            if not origin:\r\n                try: origin = elem.GetTransform().Origin\r\n                except: pass\r\n                \r\n            if not origin:\r\n                try:\r\n                    bb = elem.get_BoundingBox(None)\r\n                    if bb: origin = XYZ((bb.Min.X + bb.Max.X)/2.0, (bb.Min.Y + bb.Max.Y)/2.0, (bb.Min.Z + bb.Max.Z)/2.0)\r\n                except: pass\r\n\r\n            # 2. Ironclad Vector & Size Extraction\r\n            vec_dir = None\r\n            if origin:\r\n                try:\r\n                    if hasattr(elem, \"MEPModel\") and elem.MEPModel and elem.MEPModel.ConnectorManager:\r\n                        for conn in elem.MEPModel.ConnectorManager.Connectors:\r\n                            try: vec_dir = conn.CoordinateSystem.BasisZ\r\n                            except: pass\r\n                            \r\n                            if not vec_dir or vec_dir.IsAlmostEqualTo(XYZ.Zero):\r\n                                try: vec_dir = conn.Direction\r\n                                except: pass\r\n                                \r\n                            if vec_dir and not vec_dir.IsAlmostEqualTo(XYZ.Zero):\r\n                                # Extract dimensions directly from the terminal's connector!\r\n                                shape = conn.Shape\r\n                                if shape == ConnectorProfileType.Round:\r\n                                    radius = conn.Radius\r\n                                else:\r\n                                    width = conn.Width\r\n                                    height = conn.Height\r\n                                break\r\n                except: pass\r\n\r\n                if not vec_dir or vec_dir.IsAlmostEqualTo(XYZ.Zero):\r\n                    try: vec_dir = elem.FacingOrientation\r\n                    except: pass\r\n                    \r\n                if not vec_dir or vec_dir.IsAlmostEqualTo(XYZ.Zero):\r\n                    try: vec_dir = elem.GetTransform().BasisZ\r\n                    except: pass\r\n                    \r\n                if not vec_dir or vec_dir.IsAlmostEqualTo(XYZ.Zero):\r\n                    vec_dir = XYZ.BasisZ\r\n\r\n                # 3. Create Native Revit Centerline Curve\r\n                norm_dir = vec_dir.Normalize()\r\n                offset_vec = norm_dir.Multiply(EXT_LEN_FT)\r\n                pt_forward = origin.Add(offset_vec)\r\n                pt_reverse = origin.Subtract(offset_vec)\r\n                \r\n                # We use Revit's Line.CreateBound so it works with CreateTransformed later\r\n                loc_curve = Line.CreateBound(pt_reverse, pt_forward)\r\n                \r\n                # Fallback size if connector was completely missing\r\n                if shape is None:\r\n                    shape = ConnectorProfileType.Rectangular\r\n                    width = 300.0 / 304.8\r\n                    height = 300.0 / 304.8\r\n\r\n        # --- STEP 2: APPLY YOUR OFFSET MATH ---\r\n        # If it wasn't a duct or terminal, pass it through\r\n        if not loc_curve:\r\n            return item\r\n\r\n        p0 = loc_curve.GetEndPoint(0)\r\n        p1 = loc_curve.GetEndPoint(1)\r\n        direction = p1.Subtract(p0).Normalize()\r\n\r\n        is_vertical = abs(direction.Z) > 0.99\r\n        ref_vec = XYZ.BasisX if is_vertical else XYZ.BasisZ\r\n\r\n        side_vec = direction.CrossProduct(ref_vec).Normalize()\r\n        up_vec = side_vec.CrossProduct(direction).Normalize()\r\n\r\n        lines = []\r\n        lines.append(loc_curve.ToProtoType()) # Center\r\n\r\n        if shape == ConnectorProfileType.Round:\r\n            for i in range(8):\r\n                angle = i * (math.pi / 4)\r\n                h_comp = side_vec.Multiply(math.cos(angle))\r\n                v_comp = up_vec.Multiply(math.sin(angle))\r\n                offset_vec = h_comp.Add(v_comp).Multiply(radius)\r\n\r\n                trans = Transform.CreateTranslation(offset_vec)\r\n                lines.append(loc_curve.CreateTransformed(trans).ToProtoType())\r\n        else:\r\n            w_off = width / 2.0\r\n            h_off = height / 2.0\r\n\r\n            offsets = [\r\n                up_vec.Multiply(h_off), # Top\r\n                up_vec.Multiply(-h_off), # Bottom\r\n                side_vec.Multiply(w_off), # Left\r\n                side_vec.Multiply(-w_off), # Right\r\n                up_vec.Multiply(h_off).Add(side_vec.Multiply(w_off)), # TL\r\n                up_vec.Multiply(h_off).Add(side_vec.Multiply(-w_off)), # TR\r\n                up_vec.Multiply(-h_off).Add(side_vec.Multiply(w_off)), # BL\r\n                up_vec.Multiply(-h_off).Add(side_vec.Multiply(-w_off)) # BR\r\n            ]\r\n            for vec in offsets:\r\n                trans = Transform.CreateTranslation(vec)\r\n                lines.append(loc_curve.CreateTransformed(trans).ToProtoType())\r\n\r\n        return lines\r\n\r\n    except Exception as e:\r\n        return \"PYTHON ERROR: \" + str(e)\r\n\r\ndef process_list(input_list):\r\n    \"\"\"Recursively processes lists to handle any depth.\"\"\"\r\n    output = []\r\n    for item in input_list:\r\n        if isinstance(item, list):\r\n            output.append(process_list(item))\r\n        else:\r\n            output.append(get_offset_lines(item))\r\n    return output\r\n\r\n# --- INPUT HANDLING ---\r\ndata_in = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\n\r\nOUT = process_list(data_in)",
