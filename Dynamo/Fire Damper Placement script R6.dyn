    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\nimport math\r\n\r\n# Load Revit API\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\n# Load RevitNodes for Dynamo conversion\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n\r\ndef get_offset_lines(duct):\r\n    \"\"\"Processes a single duct and returns 9 lines (Center + 8 Perimeter).\"\"\"\r\n    try:\r\n        # Unwrap the element to access Revit API\r\n        d = UnwrapElement(duct)\r\n        loc_curve = d.Location.Curve\r\n        p0 = loc_curve.GetEndPoint(0)\r\n        p1 = loc_curve.GetEndPoint(1)\r\n        \r\n        # Vector Math using explicit methods from reference code\r\n        direction = p1.Subtract(p0).Normalize()\r\n        \r\n        # Determine orientation\r\n        is_vertical = abs(direction.Z) > 0.99\r\n        ref_vec = XYZ.BasisX if is_vertical else XYZ.BasisZ\r\n        \r\n        side_vec = direction.CrossProduct(ref_vec).Normalize()\r\n        up_vec = side_vec.CrossProduct(direction).Normalize()\r\n\r\n        shape = d.DuctType.Shape\r\n        lines = []\r\n        \r\n        # 1. Add Center Line (Standard)\r\n        lines.append(loc_curve.ToProtoType())\r\n\r\n        if shape == ConnectorProfileType.Round:\r\n            radius = d.Diameter / 2.0\r\n            # 8 Points around the circle (45 deg intervals)\r\n            for i in range(8):\r\n                angle = i * (math.pi / 4)\r\n                # Radial offset vector calculation\r\n                h_comp = side_vec.Multiply(math.cos(angle))\r\n                v_comp = up_vec.Multiply(math.sin(angle))\r\n                offset_vec = h_comp.Add(v_comp).Multiply(radius)\r\n                \r\n                trans = Transform.CreateTranslation(offset_vec)\r\n                lines.append(loc_curve.CreateTransformed(trans).ToProtoType())\r\n        \r\n        else:\r\n            w_off = d.Width / 2.0\r\n            h_off = d.Height / 2.0\r\n            \r\n            # Define 8 Offset Vectors for Rectangular Perimeter\r\n            # T, B, L, R + 4 Corners\r\n            offsets = [\r\n                up_vec.Multiply(h_off), # Top\r\n                up_vec.Multiply(-h_off), # Bottom\r\n                side_vec.Multiply(w_off), # Left\r\n                side_vec.Multiply(-w_off), # Right\r\n                up_vec.Multiply(h_off).Add(side_vec.Multiply(w_off)), # TL\r\n                up_vec.Multiply(h_off).Add(side_vec.Multiply(-w_off)), # TR\r\n                up_vec.Multiply(-h_off).Add(side_vec.Multiply(w_off)), # BL\r\n                up_vec.Multiply(-h_off).Add(side_vec.Multiply(-w_off)) # BR\r\n            ]\r\n            \r\n            for vec in offsets:\r\n                trans = Transform.CreateTranslation(vec)\r\n                lines.append(loc_curve.CreateTransformed(trans).ToProtoType())\r\n\r\n        return lines\r\n    except:\r\n        return None\r\n\r\ndef process_list(input_list):\r\n    \"\"\"Recursively processes lists to handle any depth.\"\"\"\r\n    output = []\r\n    for item in input_list:\r\n        if isinstance(item, list):\r\n            output.append(process_list(item))\r\n        else:\r\n            output.append(get_offset_lines(item))\r\n    return output\r\n\r\n# --- INPUT HANDLING ---\r\ndata_in = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\nOUT = process_list(data_in)",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "a892b9ea4f7d46bba67bc426ce23b9b1",
      "Inputs": [
        {
          "Id": "4c9485babca140139015a7001d925411",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "a2604388bea744f0a00b2c643344cdb1",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
