    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# IN[0] -> Elements (Rooms) - Supports single items or heavily nested lists\r\n# OUT -> Perfectly nested list of Transformed Autodesk.Revit.DB.Solid objects\r\n\r\nimport clr\r\nimport sys\r\n\r\n# 1. Import Revit API\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\n# 2. Import Document Manager & Core Modules\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom System.Collections.Generic import List\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# --- MODULE 1: PRE-PROCESS AND ANCHOR LINK INSTANCES ---\r\n# Gather all link instances in the host document and sort them permanently by ID\r\nall_links = list(FilteredElementCollector(doc).OfClass(RevitLinkInstance))\r\nlink_dict = {}\r\n\r\nfor link in all_links:\r\n    ldoc = link.GetLinkDocument()\r\n    if ldoc:\r\n        title = ldoc.Title\r\n        if title not in link_dict:\r\n            link_dict[title] = []\r\n        link_dict[title].append(link)\r\n        \r\nfor title in link_dict:\r\n    link_dict[title].sort(key=lambda x: x.Id.IntegerValue)\r\n\r\n# Global tracker to handle identical room IDs across duplicated links\r\nelement_counters = {}\r\n\r\n# --- MODULE 2: GEOMETRY EXTRACTION UTILITIES ---\r\ndef collect_solids_from_geom_element(geomElem):\r\n    sols = []\r\n    if geomElem is None: return sols\r\n    try:\r\n        for go in geomElem:\r\n            if isinstance(go, Solid):\r\n                try: v = go.Volume\r\n                except Exception: v = None\r\n                if v is not None and v > 1e-6:\r\n                    sols.append(go)\r\n            elif isinstance(go, GeometryInstance):\r\n                inst_geom = go.GetInstanceGeometry()\r\n                sols.extend(collect_solids_from_geom_element(inst_geom))\r\n            elif isinstance(go, GeometryElement):\r\n                sols.extend(collect_solids_from_geom_element(go))\r\n    except Exception: pass\r\n    return sols\r\n\r\ndef get_solids_for_spatial(spatial_el):\r\n    if spatial_el is None: return None\r\n    try: \r\n        cs = getattr(spatial_el, \"ClosedShell\", None)\r\n    except Exception: \r\n        cs = None\r\n    \r\n    if cs is not None:\r\n        sols = collect_solids_from_geom_element(cs)\r\n        if sols: return sols[0] # Return largest/first valid solid\r\n        \r\n    calc = None\r\n    results = None\r\n    try:\r\n        opt = SpatialElementBoundaryOptions()\r\n        # Always use the source document of the room element\r\n        calc = SpatialElementGeometryCalculator(spatial_el.Document, opt)\r\n        results = calc.CalculateSpatialElementGeometry(spatial_el)\r\n        geom = results.GetGeometry()\r\n        sols = collect_solids_from_geom_element(geom)\r\n        \r\n        if sols:\r\n            # Sort to find the largest valid solid volume\r\n            sols.sort(key=lambda s: s.Volume, reverse=True)\r\n            return sols[0]\r\n    except:\r\n        return None\r\n    finally:\r\n        # Crucial: Dispose objects instantly to unlock identical IDs in subsequent links\r\n        if results is not None: results.Dispose()\r\n        if calc is not None: calc.Dispose()\r\n    return None\r\n\r\n# --- MODULE 3: THE 1-TO-1 TRACKING ENGINE ---\r\ndef process_element_solid(item):\r\n    if item is None: return None\r\n    \r\n    elem = UnwrapElement(item)\r\n    if not hasattr(elem, \"Document\") or not hasattr(elem, \"Id\"):\r\n        return None\r\n        \r\n    element_doc = elem.Document\r\n    \r\n    # Extract the raw local solid\r\n    if not isinstance(elem, SpatialElement):\r\n        return None\r\n        \r\n    raw_solid = get_solids_for_spatial(elem)\r\n    if raw_solid is None:\r\n        return None\r\n        \r\n    # If the element belongs to the host model, no transformation is needed\r\n    if element_doc.Equals(doc):\r\n        return raw_solid\r\n        \r\n    # Process linked element via the Mathematical 1-to-1 Mapping loop\r\n    doc_title = element_doc.Title\r\n    element_id = elem.Id.IntegerValue\r\n    element_key = (doc_title, element_id)\r\n    \r\n    if element_key not in element_counters:\r\n        element_counters[element_key] = 0\r\n        \r\n    current_count = element_counters[element_key]\r\n    available_links = link_dict.get(doc_title, [])\r\n    \r\n    if not available_links:\r\n        return raw_solid\r\n    else:\r\n        # Step through link instances incrementally using the persistent counter\r\n        assigned_link = available_links[current_count % len(available_links)]\r\n        revit_transform = assigned_link.GetTotalTransform()\r\n        \r\n        # Transform the pure DB Solid object into real-world host space\r\n        if not revit_transform.IsIdentity:\r\n            try:\r\n                transformed_solid = SolidUtils.CreateTransformed(raw_solid, revit_transform)\r\n                if transformed_solid is not None:\r\n                    raw_solid = transformed_solid\r\n            except:\r\n                pass\r\n                \r\n        # Increment the counter explicitly for the next loop iteration\r\n        element_counters[element_key] += 1\r\n        return raw_solid\r\n\r\n# --- MODULE 4: RECURSIVE DATA TREE PRESERVATION ---\r\ndef process_nested_lists(item):\r\n    if isinstance(item, list):\r\n        return [process_nested_lists(x) for x in item]\r\n    else:\r\n        return process_element_solid(item)\r\n\r\n# Run the execution mapping across your exact input tree\r\nOUT = process_nested_lists(IN[0])",
      "Engine": "IronPython2",
      "VariableInputPorts": true,
      "Id": "af95e4062f9649ca95274b57d5922dd3",
      "Inputs": [
        {
          "Id": "2ce6699b50da4dda93959a776e42c7dc",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "a897bea1e2264a61abce337f8fc1ea3a",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "53a03a759e8d43faa0db8c874c25b678",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\n\r\n# Import Revit API\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import Solid, PlanarFace\r\n\r\n# --- INPUT ---\r\n# Input can be a single solid, a flat list, or a heavily nested list\r\nsolids_in = IN[0]\r\n\r\n# --- CORE LOGIC ---\r\ndef get_bottom_face(item):\r\n    \r\n    # 1. Handle Nested Lists (Recursion)\r\n    if isinstance(item, list):\r\n        return [get_bottom_face(x) for x in item]\r\n        \r\n    # 2. Handle the Solid\r\n    elif isinstance(item, Solid):\r\n        bottom_faces = []\r\n        \r\n        # Iterate all faces in the solid\r\n        for face in item.Faces:\r\n            if isinstance(face, PlanarFace):\r\n                try:\r\n                    # Check if the normal points downwards\r\n                    if face.FaceNormal.Z < -0.99:\r\n                        bottom_faces.append(face)\r\n                except:\r\n                    pass\r\n        \r\n        # 3. 1-to-1 Mapping Logic\r\n        if len(bottom_faces) == 1:\r\n            return bottom_faces[0]\r\n        elif len(bottom_faces) > 1:\r\n            # If a complex room generates multiple bottom faces, return the largest one\r\n            bottom_faces.sort(key=lambda f: f.Area, reverse=True)\r\n            return bottom_faces[0]\r\n        else:\r\n            # Returns None if the solid has no bottom face\r\n            return None\r\n            \r\n    # 3. Handle nulls or invalid inputs\r\n    else:\r\n        return None\r\n\r\n# --- OUTPUT ---\r\nOUT = get_bottom_face(solids_in)",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "f1a3b921b8244e09a2c286bc95778b1d",
      "Inputs": [
        {
          "Id": "d57dc78f356c46298627a62106c9d60f",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "7668674515214ae48ef3198d27d49314",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
