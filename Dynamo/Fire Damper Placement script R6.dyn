    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# -*- coding: utf-8 -*-\r\n# IN[0] : Wall / List / Nested List\r\n# OUT   : Height in mm (same structure)\r\n\r\nimport clr\r\n\r\n# Revit API\r\nclr.AddReference(\"RevitAPI\")\r\nfrom Autodesk.Revit.DB import BuiltInParameter\r\n\r\n# -----------------------------\r\n# Helpers\r\n# -----------------------------\r\n\r\ndef ft_to_mm(x):\r\n    return x * 304.8\r\n\r\n\r\ndef get_wall_height_mm(wall):\r\n    if wall is None:\r\n        return None\r\n\r\n    try:\r\n        # Get computed height directly\r\n        param = wall.get_Parameter(BuiltInParameter.WALL_USER_HEIGHT_PARAM)\r\n\r\n        if param and param.HasValue:\r\n            height_ft = param.AsDouble()\r\n\r\n            if height_ft <= 0:\r\n                return None\r\n\r\n            return ft_to_mm(height_ft)\r\n\r\n        return None\r\n\r\n    except:\r\n        return None\r\n\r\n\r\ndef process(data):\r\n    if isinstance(data, list):\r\n        return [process(i) for i in data]\r\n    else:\r\n        wall = UnwrapElement(data)\r\n        return get_wall_height_mm(wall)\r\n\r\n\r\n# -----------------------------\r\n# Execute\r\n# -----------------------------\r\n\r\nOUT = process(IN[0])",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "4bcae9cfb4974e5a9cd247cc0b9d59fb",
      "Inputs": [
        {
          "Id": "8eb0e811b8034173b5e39f70cfbb97e9",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "5bba4739286c4f65a79a818306286b92",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
