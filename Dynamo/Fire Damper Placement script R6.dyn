    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\n\r\n# RevitServices\r\nclr.AddReference(\"RevitServices\")\r\nfrom RevitServices.Persistence import DocumentManager\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# RevitAPI\r\nclr.AddReference(\"RevitAPI\")\r\nfrom Autodesk.Revit.DB import *\r\n\r\n# ------------------------------------------------------------\r\n# SAFE UNWRAP\r\n# ------------------------------------------------------------\r\ndef unwrap(x):\r\n    if hasattr(x, \"InternalElement\"):\r\n        return x.InternalElement\r\n    return x\r\n\r\n# ------------------------------------------------------------\r\n# FIRE DAMPER CHECK\r\n# ------------------------------------------------------------\r\ndef is_fire_damper(elem):\r\n    r = unwrap(elem)\r\n    if not r or not r.Category:\r\n        return False\r\n\r\n    # Check category\r\n    if r.Category.Name != \"Duct Accessories\":\r\n        return False\r\n\r\n    # Check family name\r\n    try:\r\n        fam_name = r.Symbol.Family.Name.lower()\r\n    except:\r\n        return False\r\n\r\n    return (\"fire\" in fam_name) and (\"damper\" in fam_name)\r\n\r\n# ------------------------------------------------------------\r\n# RECURSIVE STRUCTURE PRESERVER\r\n# ------------------------------------------------------------\r\ndef process(item):\r\n    if isinstance(item, list):\r\n        return [process(i) for i in item]\r\n    else:\r\n        if is_fire_damper(item):\r\n            return item\r\n        else:\r\n            return []\r\n\r\n# ------------------------------------------------------------\r\n# MAIN\r\n# ------------------------------------------------------------\r\ndata = IN[0]\r\nOUT = process(data)\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "2a211bf43c0d4ecebcd3fbc2bfd6d2a1",
      "Inputs": [
        {
          "Id": "a4e8278eee134d5d9e59c41b0170cc93",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "2f0cfda5eaf8451cb819287f9961c0d3",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
