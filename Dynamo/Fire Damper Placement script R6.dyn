    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# --- Inputs ---\r\nducts_in = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\npoints_in = IN[1] if isinstance(IN[1], list) else [IN[1]]\r\nstrings_in = IN[2] if isinstance(IN[2], list) else [IN[2]]\r\n\r\n# Dictionary to store accepted points per duct ID\r\n# Key = Duct Id, Value = List of accepted Point objects\r\nduct_groups = {}\r\n\r\nfinal_ducts = []\r\nfinal_points = []\r\nfinal_strings = []  # NEW: Parallel list for the mapped string data\r\n\r\n# Iterate through all three paired lists simultaneously\r\nfor duct, point, string_data in zip(ducts_in, points_in, strings_in):\r\n    if not duct or not point: \r\n        continue\r\n    \r\n    try:\r\n        d_id = duct.Id\r\n    except:\r\n        continue # Safely skip if element lacks an ID\r\n    \r\n    # If duct hasn't been seen yet, start a new list\r\n    if d_id not in duct_groups:\r\n        duct_groups[d_id] = [point]\r\n        \r\n        final_ducts.append(duct)\r\n        final_points.append(point)\r\n        final_strings.append(string_data) # Map the string\r\n    else:\r\n        # Check distance against all points already accepted for THIS duct\r\n        is_too_close = False\r\n        for accepted_pt in duct_groups[d_id]:\r\n            if point.DistanceTo(accepted_pt) < 300.0:\r\n                is_too_close = True\r\n                break\r\n        \r\n        # If the point is safe (more than 300mm from all others), keep it\r\n        if not is_too_close:\r\n            duct_groups[d_id].append(point)\r\n            \r\n            final_ducts.append(duct)\r\n            final_points.append(point)\r\n            final_strings.append(string_data) # Map the string\r\n\r\n# OUT[0] = Cleaned Ducts\r\n# OUT[1] = Cleaned Points\r\n# OUT[2] = Cleaned Strings\r\nOUT = [final_ducts, final_points, final_strings]",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "21fb0fa83d6849e5a448113071f7f362",
      "Inputs": [
        {
          "Id": "dacd41df1b374549a8f20f58b99343b4",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "dec55516a7ff4a3e86c8ba52c65cfee3",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "beb052776cc64d8dbb2153b4f7c49de3",
          "Name": "IN[2]",
          "Description": "Input #2",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "e6de517122d04fd69b47399e222c33f9",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
