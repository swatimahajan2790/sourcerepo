    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# -*- coding: utf-8 -*-\r\n# IN[0] : Dynamo Lines (may contain duplicates)\r\n# IN[1] : Mapped ducts (index aligned with IN[0])\r\n# IN[2] : Mapped string data (index aligned with IN[0])\r\n# OUT   : [uniqueLines, uniqueMappedDucts, uniqueMappedStrings]\r\n\r\nimport clr\r\n\r\nclr.AddReference(\"ProtoGeometry\")\r\nfrom Autodesk.DesignScript.Geometry import Line\r\n\r\n# -----------------------------\r\n# Helpers\r\n# -----------------------------\r\n\r\ndef to_list(obj):\r\n    if hasattr(obj, '__iter__'):\r\n        return obj\r\n    else:\r\n        return [obj]\r\n\r\ndef distance(pt1, pt2):\r\n    return pt1.DistanceTo(pt2)\r\n\r\ndef lines_are_equal(l1, l2, tol):\r\n    \"\"\"\r\n    Checks if two lines are equal within tolerance (2mm)\r\n    Handles reversed direction as well.\r\n    \"\"\"\r\n    if l1 is None or l2 is None:\r\n        return False\r\n\r\n    s1, e1 = l1.StartPoint, l1.EndPoint\r\n    s2, e2 = l2.StartPoint, l2.EndPoint\r\n\r\n    # Same direction\r\n    cond1 = (\r\n        distance(s1, s2) <= tol and\r\n        distance(e1, e2) <= tol\r\n    )\r\n\r\n    # Reversed direction\r\n    cond2 = (\r\n        distance(s1, e2) <= tol and\r\n        distance(e1, s2) <= tol\r\n    )\r\n\r\n    return cond1 or cond2\r\n\r\n# -----------------------------\r\n# Main\r\n# -----------------------------\r\n\r\nlines = to_list(IN[0]) if IN[0] else []\r\nmapped = to_list(IN[1]) if IN[1] else []\r\nstring_data = to_list(IN[2]) if IN[2] else []\r\n\r\n# Check to ensure all three lists have the same length before processing\r\nif len(lines) != len(mapped) or len(lines) != len(string_data):\r\n    OUT = [[], [], []]\r\nelse:\r\n    tol_mm = 2.0  # 2 mm tolerance\r\n\r\n    unique_lines = []\r\n    unique_mapped = []\r\n    unique_strings = []\r\n\r\n    # Zip all three lists together so they stay perfectly aligned\r\n    for line, data, s_data in zip(lines, mapped, string_data):\r\n\r\n        if not isinstance(line, Line):\r\n            continue\r\n\r\n        is_duplicate = False\r\n\r\n        for existing in unique_lines:\r\n            if lines_are_equal(line, existing, tol_mm):\r\n                is_duplicate = True\r\n                break\r\n\r\n        if not is_duplicate:\r\n            unique_lines.append(line)\r\n            unique_mapped.append(data)\r\n            unique_strings.append(s_data) # Keep the string data aligned\r\n\r\n    OUT = [unique_lines, unique_mapped, unique_strings]",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "fb6efad3ec694574bd1c1ba41b5ae842",
      "Inputs": [
        {
          "Id": "55673f7811d04016872c4781fdbaeea7",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "5b4e931816494f31a45ecb5ab54cd555",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "815cfda6b238435db8aca59bf9e98775",
          "Name": "IN[2]",
          "Description": "Input #2",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "a5da8b0a8bc94a9885b9ab3970d84111",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
