          "Description": "The parameter at which to evaluate\n\ndouble\nDefault value : 0",
          "UsingDefaultValue": true,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "fe0cbb67d0524a87add32466d69cb390",
          "Name": "Point",
          "Description": "Point",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Auto",
      "Description": "Get a Point on the Curve at a specified parameter between StartParameter() and EndParameter()\n\nCurve.PointAtParameter (param: double = 0): Point"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\ndef process_placement():\r\n    # Constants in mm\r\n    DAMPER_WIDTH = 150.0\r\n    CLEARANCE = 25.0\r\n    \r\n    # Center of damper must be at least 100mm from duct ends\r\n    SAFE_BUFFER = (DAMPER_WIDTH / 2.0) + CLEARANCE \r\n    MIN_TOTAL_LENGTH = DAMPER_WIDTH + (2 * CLEARANCE) # 200mm\r\n\r\n    # Ensure inputs are treated as lists\r\n    ducts = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\n    lines = IN[1] if isinstance(IN[1], list) else [IN[1]]\r\n    points = IN[2] if isinstance(IN[2], list) else [IN[2]]\r\n    strings = IN[3] if isinstance(IN[3], list) else [IN[3]] # NEW: String Data Input\r\n\r\n    success_ducts = []\r\n    success_points = []\r\n    success_strings = [] # NEW\r\n\r\n    failed_ducts = []\r\n    failed_msgs = []\r\n    failed_strings = [] # NEW\r\n\r\n    # Iterate through all inputs, now zipping 4 parallel lists\r\n    for d, l, p, s in zip(ducts, lines, points, strings):\r\n        if not d or not l or not p:\r\n            continue\r\n            \r\n        total_length = l.Length\r\n\r\n        # 1. Filter: Check if duct is too short\r\n        if total_length < MIN_TOTAL_LENGTH:\r\n            failed_ducts.append(d)\r\n            failed_msgs.append(\"Place damper Manually - Dont have enough length to place damper\")\r\n            failed_strings.append(s) # Map string to failure list\r\n            continue\r\n        \r\n        # 2. Project input point to the duct line axis\r\n        proj_point = l.ClosestPointTo(p)\r\n        \r\n        # 3. Calculate distances from ends\r\n        dist_start = l.StartPoint.DistanceTo(proj_point)\r\n        dist_end = l.EndPoint.DistanceTo(proj_point)\r\n        \r\n        final_point = proj_point\r\n        \r\n        # 4. Adjustment Logic (Shifting)\r\n        if dist_start < SAFE_BUFFER:\r\n            # Shift away from Start\r\n            move_vec = l.Direction\r\n            move_dist = SAFE_BUFFER - dist_start\r\n            final_point = proj_point.Translate(move_vec, move_dist)\r\n            \r\n        elif dist_end < SAFE_BUFFER:\r\n            # Shift away from End\r\n            move_vec = l.Direction.Reverse()\r\n            move_dist = SAFE_BUFFER - dist_end\r\n            final_point = proj_point.Translate(move_vec, move_dist)\r\n            \r\n        # Add to success list\r\n        success_ducts.append(d)\r\n        success_points.append(final_point)\r\n        success_strings.append(s) # Map string to success list\r\n\r\n    # Return grouped outputs\r\n    return [[success_ducts, success_points, success_strings], [failed_ducts, failed_msgs, failed_strings]]\r\n\r\nOUT = process_placement()",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "4a802d4f149d49118656714407af8c64",
      "Inputs": [
        {
          "Id": "9ccc793884f54cc18a128b250f97918b",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "7de74032da1846cf8bb5661217e5d2cb",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "5d28889f98b0450192c044b490733b1c",
          "Name": "IN[2]",
          "Description": "Input #2",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "85c4b9f65cef4ff78d31a926467837b9",
          "Name": "IN[3]",
          "Description": "Input #3",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "8d21be2c97a94b97b751fee7f581491b",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
