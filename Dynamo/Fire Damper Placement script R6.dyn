    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\n\r\n# Import Revit API\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\n# Import Dynamo Geometry Conversion capabilities\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n\r\n# The input data (can be a single item, a list, or a deeply nested list)\r\ninput_data = IN[0]\r\n\r\n# Recursive function to preserve exact list structure\r\ndef get_curves_from_faces(item):\r\n    # If the item is a list, dive deeper and process its contents\r\n    if isinstance(item, list):\r\n        return [get_curves_from_faces(x) for x in item]\r\n    \r\n    # If it's not a list, assume it's a Face and extract curves\r\n    else:\r\n        face_loops = []\r\n        try:\r\n            # Extract the boundary loops from the Revit face\r\n            curve_loops = item.GetEdgesAsCurveLoops()\r\n            \r\n            for loop in curve_loops:\r\n                loop_curves = []\r\n                for curve in loop:\r\n                    # Convert Revit DB Curve to Dynamo Curve\r\n                    loop_curves.append(curve.ToProtoType())\r\n                \r\n                # Append the closed loop to the face's list\r\n                face_loops.append(loop_curves)\r\n        except:\r\n            # If it fails or is null, return an empty list to maintain index mapping\r\n            pass\r\n            \r\n        return face_loops\r\n\r\n# Run the function and output the structured lists\r\nOUT = get_curves_from_faces(input_data)",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "1fd284e6085b423eace856fb7c9f143c",
      "Inputs": [
        {
          "Id": "fbefa83d911146c590c0771e4f2f3b47",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
