    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\n\r\n# Import Revit API\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import Wall\r\n\r\n# Metric Conversion\r\nFEET_TO_MM = 304.8\r\n\r\ndef get_wall_thickness(item):\r\n    if item is None:\r\n        return None\r\n        \r\n    try:\r\n        # Safely unwrap Dynamo elements to access the native Revit DB object\r\n        elem = item.InternalElement if hasattr(item, \"InternalElement\") else item\r\n        \r\n        # Ensure the element is actually a Wall before querying\r\n        if isinstance(elem, Wall):\r\n            width_ft = elem.Width\r\n            return width_ft * FEET_TO_MM\r\n        else:\r\n            return \"Not a Wall\"\r\n            \r\n    except Exception as e:\r\n        return \"PYTHON ERROR: \" + str(e)\r\n\r\n# Recursive engine to perfectly maintain nested list structures\r\ndef process_data(data):\r\n    if isinstance(data, (list, tuple)):\r\n        return [process_data(x) for x in data]\r\n    else:\r\n        return get_wall_thickness(data)\r\n\r\n# --- EXECUTION ---\r\nOUT = process_data(IN[0])",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "ab5d3661af984684a06d6bc35c340aa2",
      "Inputs": [
        {
          "Id": "8e3e251b04274ea5afc23c0e37ee2fab",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "8c9be11b610045eb8b3a2b5c8d9f9523",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
