    {
      "ConcreteType": "Dynamo.Graph.Nodes.ZeroTouch.DSFunction, DynamoCore",
      "NodeType": "FunctionNode",
      "FunctionSignature": "Autodesk.DesignScript.Geometry.Surface.Thicken@double,bool",
      "Id": "efffe635a5db462496d00cd810f7abf8",
      "Inputs": [
        {
          "Id": "d5e3bd907bf846eaa7059b77c4c90de9",
          "Name": "surface",
          "Description": "Autodesk.DesignScript.Geometry.Surface",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "c383f85235c348bc9d00e9ae6b294c97",
          "Name": "thickness",
          "Description": "Amount to thicken\n\ndouble\nDefault value : 1",
          "UsingDefaultValue": true,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "dfbb0bd2234445788698a6ffcd043f99",
          "Name": "both_sides",
          "Description": "True to thicken on both sides, false to thicken on one side\n\nbool\nDefault value : true",
          "UsingDefaultValue": true,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "0f92f05f9bdb450ab4e307a7d95a2a49",
          "Name": "Solid",
          "Description": "Thickened surface as solid",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Auto",
      "Description": "Thicken Surface into a Solid, extruding in the direction of Surface normals. If both_sides parameter is true, surface is thickened on both sides.\n\nSurface.Thicken (thickness: double = 1, both_sides: bool = true): Solid"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\nimport math\r\n\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import Line, Point, Vector\r\n\r\n# ---------------------------\r\n# PARAMETERS\r\n# ---------------------------\r\nMAX_GAP_MM = 500.0\r\nCOLLINEAR_TOL_MM = 1e-6   \r\nANG_TOL_RAD = 1e-6\r\nEPS = 1e-12\r\n\r\n# ---------------------------\r\n# BASIC HELPERS\r\n# ---------------------------\r\ndef as_list(x):\r\n    if x is None:\r\n        return []\r\n    if isinstance(x, Line):\r\n        return [x]\r\n    try:\r\n        return [i for i in x if i is not None]\r\n    except:\r\n        return []\r\n\r\ndef v_len(v):\r\n    return math.sqrt(v.X*v.X + v.Y*v.Y + v.Z*v.Z)\r\n\r\ndef v_dot(a, b):\r\n    return a.X*b.X + a.Y*b.Y + a.Z*b.Z\r\n\r\ndef v_cross(a, b):\r\n    return Vector.ByCoordinates(\r\n        a.Y*b.Z - a.Z*b.Y,\r\n        a.Z*b.X - a.X*b.Z,\r\n        a.X*b.Y - a.Y*b.X\r\n    )\r\n\r\ndef pt_sub(a, b):\r\n    return Vector.ByCoordinates(a.X - b.X, a.Y - b.Y, a.Z - b.Z)\r\n\r\ndef v_unit(v):\r\n    l = v_len(v)\r\n    if l < EPS:\r\n        return None\r\n    return Vector.ByCoordinates(v.X/l, v.Y/l, v.Z/l)\r\n\r\ndef line_dir(l):\r\n    return pt_sub(l.EndPoint, l.StartPoint)\r\n\r\ndef line_dir_unit(l):\r\n    return v_unit(line_dir(l))\r\n\r\ndef midpoint(l):\r\n    s, e = l.StartPoint, l.EndPoint\r\n    return Point.ByCoordinates((s.X+e.X)/2.0, (s.Y+e.Y)/2.0, (s.Z+e.Z)/2.0)\r\n\r\n# ---------------------------\r\n# GEOMETRY TESTS\r\n# ---------------------------\r\ndef are_parallel(u_unit, v_unit, angTol=ANG_TOL_RAD):\r\n    c = v_cross(u_unit, v_unit)\r\n    return v_len(c) <= math.sin(angTol) + 1e-15\r\n\r\ndef point_to_infinite_line_distance(p, a, u_vec):\r\n    ap = pt_sub(p, a)\r\n    cu = v_cross(ap, u_vec)\r\n    denom = v_len(u_vec)\r\n    if denom < EPS:\r\n        return float('inf')\r\n    return v_len(cu) / denom\r\n\r\ndef point_on_infinite_line(p, a, u_vec, tolMm=COLLINEAR_TOL_MM):\r\n    return point_to_infinite_line_distance(p, a, u_vec) <= tolMm\r\n\r\ndef strictly_collinear(l1, l2):\r\n    u1u = line_dir_unit(l1)\r\n    u2u = line_dir_unit(l2)\r\n    if u1u is None or u2u is None:\r\n        return False\r\n    if not are_parallel(u1u, u2u):\r\n        return False\r\n\r\n    a = l1.StartPoint\r\n    u = line_dir(l1)  \r\n    if not point_on_infinite_line(l2.StartPoint, a, u, COLLINEAR_TOL_MM):\r\n        return False\r\n    if not point_on_infinite_line(l2.EndPoint, a, u, COLLINEAR_TOL_MM):\r\n        return False\r\n    return True\r\n\r\ndef signed_param_on_line(p, a, u_unit):\r\n    return v_dot(pt_sub(p, a), u_unit)\r\n\r\ndef midpoint_gap_along_line(l1, l2):\r\n    u = line_dir_unit(l1)\r\n    if u is None:\r\n        return float('inf')\r\n    a = l1.StartPoint\r\n    t1 = signed_param_on_line(midpoint(l1), a, u)\r\n    t2 = signed_param_on_line(midpoint(l2), a, u)\r\n    return abs(t2 - t1)\r\n\r\n# ---------------------------\r\n# CONNECTED COMPONENTS\r\n# ---------------------------\r\ndef connected_components(indices, link_fn):\r\n    idx_list = list(indices)\r\n    m = len(idx_list)\r\n    if m <= 1:\r\n        return [idx_list]\r\n\r\n    adj = [[] for _ in range(m)]\r\n    for i in range(m):\r\n        for j in range(i+1, m):\r\n            if link_fn(idx_list[i], idx_list[j]):\r\n                adj[i].append(j)\r\n                adj[j].append(i)\r\n\r\n    visited = [False]*m\r\n    comps = []\r\n    for i in range(m):\r\n        if visited[i]:\r\n            continue\r\n        stack = [i]\r\n        visited[i] = True\r\n        comp = []\r\n        while stack:\r\n            k = stack.pop()\r\n            comp.append(idx_list[k])\r\n            for nb in adj[k]:\r\n                if not visited[nb]:\r\n                    visited[nb] = True\r\n                    stack.append(nb)\r\n        comps.append(comp)\r\n    return comps\r\n\r\n# ---------------------------\r\n# MAIN GROUPING\r\n# ---------------------------\r\ndef group_indices_by_rules(lines):\r\n    n = len(lines)\r\n    if n == 0:\r\n        return []\r\n    if n == 1:\r\n        return [[0]]\r\n\r\n    all_idx = range(n)\r\n\r\n    # Step 1: strict collinear components\r\n    collinear_comps = connected_components(\r\n        all_idx,\r\n        lambda i, j: strictly_collinear(lines[i], lines[j]) or strictly_collinear(lines[j], lines[i])\r\n    )\r\n\r\n    # Step 2: split by midpoint gap\r\n    final_idx_groups = []\r\n    for comp in collinear_comps:\r\n        gap_comps = connected_components(\r\n            comp,\r\n            lambda i, j: (strictly_collinear(lines[i], lines[j]) or strictly_collinear(lines[j], lines[i])) and\r\n                         (midpoint_gap_along_line(lines[i], lines[j]) <= MAX_GAP_MM + 1e-6)\r\n        )\r\n        for g in gap_comps:\r\n            final_idx_groups.append(g)\r\n\r\n    return final_idx_groups\r\n\r\n# ---------------------------\r\n# Inputs\r\n# ---------------------------\r\n\r\nraw_lines = as_list(IN[0])\r\nlines = [l for l in raw_lines if isinstance(l, Line)]\r\n\r\nmapped = IN[1]  \r\nmapped_list = []\r\nif mapped is None:\r\n    mapped_list = []\r\nelse:\r\n    try:\r\n        mapped_list = list(mapped)\r\n    except:\r\n        mapped_list = [mapped]\r\n\r\nstring_data = IN[2]  \r\nstring_list = []\r\nif string_data is None:\r\n    string_list = []\r\nelse:\r\n    try:\r\n        string_list = list(string_data)\r\n    except:\r\n        string_list = [string_data]\r\n\r\n\r\n# ---------------------------\r\n# Compute groups\r\n# ---------------------------\r\n\r\nidx_groups = group_indices_by_rules(lines)\r\ngrouped_lines = [[lines[i] for i in grp] for grp in idx_groups]\r\n\r\n# Group mapped items and string data using SAME indices\r\ngrouped_mapped = []\r\ngrouped_strings = []\r\n\r\nfor grp in idx_groups:\r\n    g_mapped = []\r\n    g_strings = []\r\n    \r\n    for i in grp:\r\n        # Map IN[1]\r\n        if 0 <= i < len(mapped_list):\r\n            g_mapped.append(mapped_list[i])\r\n        else:\r\n            g_mapped.append(None) \r\n            \r\n        # Map IN[2]\r\n        if 0 <= i < len(string_list):\r\n            g_strings.append(string_list[i])\r\n        else:\r\n            g_strings.append(None) \r\n\r\n    grouped_mapped.append(g_mapped)\r\n    grouped_strings.append(g_strings)\r\n\r\nOUT = (grouped_lines, grouped_mapped, grouped_strings)",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "1df05b271ead4a1dbee8859aa12786bb",
