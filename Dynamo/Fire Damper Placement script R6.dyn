    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\nimport sys\r\n\r\n# 1. Import Revit API\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\n# 2. Import Dynamo Geometry & Element Wrapper\r\nclr.AddReference(\"RevitNodes\")\r\nimport Revit\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\nclr.ImportExtensions(Revit.Elements)\r\n\r\n# 3. Import Document Manager & Collections\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom System.Collections.Generic import List\r\n\r\n# --- INPUTS ---\r\ndynamo_curves = IN[0]\r\nraw_links_input = UnwrapElement(IN[1])\r\n\r\nhost_doc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# --- MODULE 1: Bulletproof Link Extractor ---\r\ndef get_links(items):\r\n    links = []\r\n    if items is None: return links\r\n    if isinstance(items, list):\r\n        for i in items: links.extend(get_links(i))\r\n    else:\r\n        if isinstance(items, RevitLinkInstance): links.append(items)\r\n    return links\r\n\r\nflat_links = get_links(raw_links_input)\r\n\r\n# --- MODULE 2: Coordinate Space & Transform Tracking ---\r\n# Convert Revit Identity Transform to a Dynamo CoordinateSystem for the Host\r\nhost_cs = Transform.Identity.ToCoordinateSystem()\r\nsearch_targets = [(host_doc, Transform.Identity, host_cs)]\r\n\r\nfor link in flat_links:\r\n    link_doc = link.GetLinkDocument()\r\n    if link_doc is not None:\r\n        total_transform = link.GetTotalTransform()\r\n        inv_transform = total_transform.Inverse\r\n        \r\n        # Convert Link Transform to a Dynamo CoordinateSystem\r\n        link_cs = total_transform.ToCoordinateSystem()\r\n        search_targets.append((link_doc, inv_transform, link_cs))\r\n\r\n# --- MODULE 3: Metric Tolerances ---\r\nZ_SHIFT_MM = 600.0     \r\nBOX_HEIGHT_MM = 650.0  \r\n\r\nSEARCH_RADIUS_MM = 25.0  \r\nMAX_CENTERLINE_DIST_MM = 1000.0 \r\n\r\ndef mm_to_ft(mm): return mm / 304.8\r\n\r\nbboxVec = XYZ(mm_to_ft(SEARCH_RADIUS_MM), mm_to_ft(SEARCH_RADIUS_MM), mm_to_ft(BOX_HEIGHT_MM))\r\nz_shift_vec = XYZ(0, 0, mm_to_ft(Z_SHIFT_MM))\r\n\r\n# Category Filters\r\nbics = [BuiltInCategory.OST_Walls, BuiltInCategory.OST_StructuralColumns, BuiltInCategory.OST_Columns, BuiltInCategory.OST_RoomSeparationLines]\r\nbicCol = List[BuiltInCategory](bics)\r\ncatFilter = ElementMulticategoryFilter(bicCol)\r\n\r\n# --- MODULE 4: Core Intersection & Verification Logic ---\r\ndef get_bounding_element(dynamo_curve):\r\n    try:\r\n        if dynamo_curve.__class__.__name__ == \"PolyCurve\":\r\n            return \"ERROR: Explode PolyCurve into lines first.\", None\r\n            \r\n        revit_curve = dynamo_curve.ToRevitType()\r\n        host_midpoint = revit_curve.ComputeDerivatives(0.5, True).Origin.Add(z_shift_vec)\r\n        boundary_dir = revit_curve.ComputeDerivatives(0.5, True).BasisX.Normalize()\r\n        \r\n        # Unpack the dynamo_cs here\r\n        for doc, inv_transform, dynamo_cs in search_targets:\r\n            local_midpoint = inv_transform.OfPoint(host_midpoint)\r\n            local_boundary_dir = inv_transform.OfVector(boundary_dir)\r\n            \r\n            bbox = BoundingBoxXYZ()\r\n            bbox.Min = local_midpoint.Subtract(bboxVec)\r\n            bbox.Max = local_midpoint.Add(bboxVec)\r\n            bboxFilter = BoundingBoxIntersectsFilter(Outline(bbox.Min, bbox.Max))\r\n            \r\n            collector = FilteredElementCollector(doc)\r\n            results = collector.WherePasses(bboxFilter).WherePasses(catFilter).ToElements()\r\n            \r\n            if len(results) > 0:\r\n                best_elem = None\r\n                min_dist = 1000000.0 \r\n                \r\n                for elem in results:\r\n                    try:\r\n                        loc = elem.Location\r\n                        cat_id = elem.Category.Id.IntegerValue\r\n                        is_column = (cat_id == int(BuiltInCategory.OST_StructuralColumns) or cat_id == int(BuiltInCategory.OST_Columns))\r\n                        \r\n                        if isinstance(loc, LocationCurve):\r\n                            curve = loc.Curve\r\n                            projected = curve.Project(local_midpoint)\r\n                            \r\n                            if projected is not None:\r\n                                if projected.Distance <= mm_to_ft(MAX_CENTERLINE_DIST_MM):\r\n                                    if is_column:\r\n                                        if projected.Distance < min_dist:\r\n                                            min_dist = projected.Distance\r\n                                            best_elem = elem\r\n                                    else:\r\n                                        touch_param = projected.Parameter\r\n                                        elem_dir = curve.ComputeDerivatives(touch_param, False).BasisX.Normalize()\r\n                                        dot = abs(local_boundary_dir.DotProduct(elem_dir))\r\n                                        \r\n                                        if dot > 0.95:\r\n                                            if projected.Distance < min_dist:\r\n                                                min_dist = projected.Distance\r\n                                                best_elem = elem\r\n                                                \r\n                        elif isinstance(loc, LocationPoint):\r\n                            pt = loc.Point\r\n                            pt_flat = XYZ(pt.X, pt.Y, local_midpoint.Z)\r\n                            dist = pt_flat.DistanceTo(local_midpoint)\r\n                            \r\n                            if dist <= mm_to_ft(MAX_CENTERLINE_DIST_MM):\r\n                                if dist < min_dist:\r\n                                    min_dist = dist\r\n                                    best_elem = elem\r\n                    except:\r\n                        pass\r\n                        \r\n                if best_elem is not None:\r\n                    try: \r\n                        # Return the Dynamo CoordinateSystem instead of the link instance\r\n                        return best_elem.ToDSType(False), dynamo_cs\r\n                    except: \r\n                        return \"Linked Element: \" + best_elem.Name, dynamo_cs\r\n                        \r\n        return None, None\r\n        \r\n    except Exception as e:\r\n        return \"PYTHON ERROR: \" + str(e), None\r\n\r\n# --- MODULE 5: Data Structure Processing ---\r\ndef process_data(item):\r\n    if isinstance(item, list): \r\n        return [process_data(x) for x in item]\r\n    else: \r\n        elem, cs = get_bounding_element(item)\r\n        return (item, elem, cs)\r\n\r\nraw_tree = process_data(dynamo_curves)\r\n\r\ndef extract_layer(tree, index):\r\n    if isinstance(tree, tuple): \r\n        return tree[index]\r\n    elif isinstance(tree, list): \r\n        return [extract_layer(x, index) for x in tree]\r\n    else: \r\n        return tree\r\n\r\n# --- OUTPUT ---\r\nOUT = [\r\n    extract_layer(raw_tree, 0), \r\n    extract_layer(raw_tree, 1), \r\n    extract_layer(raw_tree, 2)\r\n]",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "946da2370a0042b8aa822422b9fffd03",
      "Inputs": [
        {
          "Id": "cb6eaf9b1e0b480889a7932caed4f12a",
