    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# -*- coding: utf-8 -*-\r\nimport clr\r\n\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript import Geometry as dg\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import XYZ, FamilyInstance, BuiltInCategory\r\nfrom Autodesk.Revit.DB.Mechanical import Duct\r\n\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n\r\n# Extension length: 200mm each way (400mm total centerline)\r\nEXT_LEN_FT = 200.0 / 304.8\r\nFEET_TO_MM = 304.8 # Added multiplier to fix the Dynamo workspace scale\r\n\r\ndef get_vector_line_or_curve(item):\r\n    if item is None: \r\n        return None\r\n        \r\n    # Pass text/metadata strings or numbers through completely untouched\r\n    if isinstance(item, (str, int, float, bool)):\r\n        return item\r\n        \r\n    try:\r\n        elem = UnwrapElement(item)\r\n        if not elem or not hasattr(elem, \"IsValidObject\") or not elem.IsValidObject:\r\n            return item\r\n            \r\n        # --- SCENARIO 1: RIGID DUCT ---\r\n        if isinstance(elem, Duct):\r\n            try:\r\n                # ToProtoType() automatically scales feet to your workspace mm\r\n                return elem.Location.Curve.ToProtoType()\r\n            except:\r\n                pass \r\n                \r\n        # --- SCENARIO 2: AIR TERMINALS & FAMILY INSTANCES ---\r\n        cat_id = elem.Category.Id.IntegerValue if elem.Category else 0\r\n        is_terminal = (cat_id == int(BuiltInCategory.OST_DuctTerminal))\r\n        \r\n        if isinstance(elem, FamilyInstance) or is_terminal:\r\n            \r\n            # 1. IRONCLAD ORIGIN EXTRACTION\r\n            origin = None\r\n            try:\r\n                if elem.Location and hasattr(elem.Location, \"Point\"):\r\n                    origin = elem.Location.Point\r\n            except: pass\r\n            \r\n            if not origin:\r\n                try: origin = elem.GetTransform().Origin\r\n                except: pass\r\n                \r\n            if not origin:\r\n                try:\r\n                    bb = elem.get_BoundingBox(None)\r\n                    # CPython3 safe division\r\n                    if bb: \r\n                        origin = XYZ((bb.Min.X + bb.Max.X)/2.0, (bb.Min.Y + bb.Max.Y)/2.0, (bb.Min.Z + bb.Max.Z)/2.0)\r\n                except: pass\r\n                \r\n            # 2. IRONCLAD VECTOR EXTRACTION\r\n            if origin:\r\n                vec_dir = None\r\n                \r\n                try:\r\n                    if hasattr(elem, \"MEPModel\") and elem.MEPModel and elem.MEPModel.ConnectorManager:\r\n                        for conn in elem.MEPModel.ConnectorManager.Connectors:\r\n                            try: vec_dir = conn.CoordinateSystem.BasisZ\r\n                            except: pass\r\n                            \r\n                            if not vec_dir or vec_dir.IsAlmostEqualTo(XYZ.Zero):\r\n                                try: vec_dir = conn.Direction\r\n                                except: pass\r\n                                \r\n                            if vec_dir and not vec_dir.IsAlmostEqualTo(XYZ.Zero):\r\n                                break\r\n                except: pass\r\n                \r\n                if not vec_dir or vec_dir.IsAlmostEqualTo(XYZ.Zero):\r\n                    try: vec_dir = elem.FacingOrientation\r\n                    except: pass\r\n                    \r\n                if not vec_dir or vec_dir.IsAlmostEqualTo(XYZ.Zero):\r\n                    try: vec_dir = elem.GetTransform().BasisZ\r\n                    except: pass\r\n                    \r\n                if not vec_dir or vec_dir.IsAlmostEqualTo(XYZ.Zero):\r\n                    vec_dir = XYZ.BasisZ \r\n                    \r\n                # 3. GENERATE THE LINE (With explicit Metric conversion)\r\n                try:\r\n                    norm_dir = vec_dir.Normalize()\r\n                    \r\n                    # Math in Revit's internal Feet\r\n                    offset_vec = norm_dir.Multiply(EXT_LEN_FT)\r\n                    pt_forward = origin.Add(offset_vec)\r\n                    pt_reverse = origin.Subtract(offset_vec)\r\n                    \r\n                    # SCALE FIX: Convert feet back to mm for Dynamo\r\n                    p_start = dg.Point.ByCoordinates(pt_reverse.X * FEET_TO_MM, pt_reverse.Y * FEET_TO_MM, pt_reverse.Z * FEET_TO_MM)\r\n                    p_end = dg.Point.ByCoordinates(pt_forward.X * FEET_TO_MM, pt_forward.Y * FEET_TO_MM, pt_forward.Z * FEET_TO_MM)\r\n                    \r\n                    return dg.Line.ByStartPointEndPoint(p_start, p_end)\r\n                except Exception as e:\r\n                    return \"PYTHON MATH ERROR: \" + str(e)\r\n                    \r\n        return item\r\n    except:\r\n        return item\r\n\r\n# Recursive Data Tree engine\r\ndef process_data_tree(data):\r\n    if isinstance(data, (list, tuple)):\r\n        return [process_data_tree(x) for x in data]\r\n    else:\r\n        return get_vector_line_or_curve(data)\r\n\r\n# --- Main Execution ---\r\nOUT = process_data_tree(IN[0])",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "0ac926ae28de4441b7730afa1c21cc05",
      "Inputs": [
        {
          "Id": "635b5b35805549b18369d28435448813",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "6992b0f664b44e369deb35749dce4721",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\n\r\n# Helper function to safely flatten nested lists and extract Element IDs\r\ndef extract_id_set(input_data):\r\n    if not input_data:\r\n        return set()\r\n        \r\n    flat_list = []\r\n    def flatten(item):\r\n        if isinstance(item, (list, tuple)):\r\n            for sub_item in item:\r\n                flatten(sub_item)\r\n        elif item is not None:\r\n            flat_list.append(item)\r\n            \r\n    flatten(input_data)\r\n    \r\n    id_set = set()\r\n    for elem in flat_list:\r\n        try:\r\n            # Handle both Dynamo unwrapped elements and raw Revit DB elements\r\n            if hasattr(elem, \"InternalElement\"):\r\n                id_set.add(elem.InternalElement.Id.IntegerValue)\r\n            elif hasattr(elem, \"Id\"):\r\n                id_set.add(elem.Id.IntegerValue)\r\n        except:\r\n            pass\r\n            \r\n    return id_set\r\n\r\n# --- INPUTS ---\r\nin0 = IN[0] if len(IN) > 0 else []\r\nin1 = IN[1] if len(IN) > 1 else []\r\nin2 = IN[2] if len(IN) > 2 else []\r\n\r\n# Convert inputs into mathematical Sets of Element IDs\r\nset0 = extract_id_set(in0)\r\nset1 = extract_id_set(in1)\r\nset2 = extract_id_set(in2)\r\n\r\n# State flags\r\nhas_0 = len(set0) > 0\r\nempty_0 = len(set0) == 0\r\n\r\nempty_1 = len(set1) == 0\r\nempty_2 = len(set2) == 0\r\n\r\n# Ensuring IN[1] actually has elements for the \"has all\" logic to make sense\r\nhas_1 = len(set1) > 0 \r\n\r\n# --- EVALUATE LOGIC RULES ---\r\n\r\n# 1. IF IN[1], IN[2] ARE EMPTY AND IN[0] HAS SOME ELEMENTS\r\ncond1 = empty_1 and empty_2 and has_0\r\n\r\n# 2. IF IN[0] IS EMPTY AND IN[2] HAS ALL ELEMENTS OF IN[1]\r\ncond2 = empty_0 and has_1 and set1.issubset(set2)\r\n\r\n# 3. IF IN[0] HAS DUCTS AND IN[2] HAS ALL DUCTS OF IN[1]\r\ncond3 = has_0 and has_1 and set1.issubset(set2)\r\n\r\n# --- OUTPUT ---\r\nif cond1 or cond2 or cond3:\r\n    OUT = True\r\nelse:\r\n    OUT = False",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "d54f764e3d0d4a0eb4bcc3396c1da0a4",
      "Inputs": [
        {
          "Id": "8e4685fde6684b9bb688980bc9c34f8e",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "720f73350c014a2c9a33c02359665bdd",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "bf10c938f709407ba4c2a229caa54456",
          "Name": "IN[2]",
          "Description": "Input #2",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
