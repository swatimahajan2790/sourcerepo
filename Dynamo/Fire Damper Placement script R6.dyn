    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\n# Inputs\r\nducts = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\npoints = IN[1] if isinstance(IN[1], list) else [IN[1]]\r\n\r\n# Output Lists\r\nrect_ducts = []\r\nrect_points = []\r\nround_ducts = []\r\nround_points = []\r\n\r\nfor d, p in zip(ducts, points):\r\n    if not d: continue\r\n    \r\n    # Get the duct element (unwrap if necessary)\r\n    obj = UnwrapElement(d)\r\n    \r\n    # Check Shape\r\n    # 1 = Round, 2 = Rectangular, 3 = Oval\r\n    shape = obj.DuctType.Shape\r\n    \r\n    if shape == ConnectorProfileType.Round:\r\n        round_ducts.append(d)\r\n        round_points.append(p)\r\n    else:\r\n        # Groups Rectangular and Oval together\r\n        rect_ducts.append(d)\r\n        rect_points.append(p)\r\n\r\n# Output: \r\n# 0 = Rectangular/Oval [Ducts, Points]\r\n# 1 = Round [Ducts, Points]\r\nOUT = [[rect_ducts, rect_points], [round_ducts, round_points]]",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "c33adf1cae334001bb3ea397ecaa7c7f",
