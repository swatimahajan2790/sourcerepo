      "Description": "Flattens a nested list of lists by a certain amount.\n\nList.Flatten (list: var[]..[], amount: int = -1): var[]..[]"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\n\r\nclr.AddReference(\"PresentationFramework\")\r\nclr.AddReference(\"PresentationCore\")\r\nclr.AddReference(\"WindowsBase\")\r\n\r\nimport System\r\nfrom System.Windows import Window, WindowStartupLocation, FontWeights, Thickness\r\nfrom System.Windows.Controls import TextBlock, Button, StackPanel, ScrollViewer\r\nfrom System.Windows import HorizontalAlignment\r\nfrom System.Windows.Media import Brushes\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\nclr.AddReference(\"RevitNodes\")\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\n\r\n# -------------------------------\r\n# INPUTS\r\n# -------------------------------\r\ndampers_input = IN[0] if len(IN) > 0 else None\r\nwarnings_input = IN[1] if len(IN) > 1 else None\r\n\r\n# Safe extraction for the boolean flag\r\nis_already_placed = False\r\nif len(IN) > 2 and IN[2] is not None:\r\n    val = IN[2]\r\n    if isinstance(val, list) and len(val) > 0:\r\n        is_already_placed = bool(val[0])\r\n    else:\r\n        is_already_placed = bool(val)\r\n\r\n# -------------------------------\r\n# HELPERS\r\n# -------------------------------\r\ndef flatten_list(lst):\r\n    if not lst:\r\n        return []\r\n    result = []\r\n    for i in lst:\r\n        if isinstance(i, (list, tuple)):\r\n            result.extend(flatten_list(i))\r\n        elif i is not None:\r\n            result.append(i)\r\n    return result\r\n\r\ndef safe_unwrap_and_flatten(inp):\r\n    if not inp:\r\n        return []\r\n    try:\r\n        return flatten_list(UnwrapElement(inp))\r\n    except:\r\n        return flatten_list(inp)\r\n\r\n# -------------------------------\r\n# COUNTS\r\n# -------------------------------\r\ndamper_list = safe_unwrap_and_flatten(dampers_input)\r\nwarning_list = safe_unwrap_and_flatten(warnings_input)\r\n\r\ndamper_count = len(damper_list)\r\nwarning_count = len(warning_list)\r\n\r\n# -------------------------------\r\n# POPUP WINDOW\r\n# -------------------------------\r\nclass ClashPopup(Window):\r\n    def __init__(self, message, bg_color, title=\"UI - DarCDT-Mechanical [2025]\"):\r\n        self.Title = title\r\n        self.Width = 440\r\n        self.Height = 210\r\n        self.WindowStartupLocation = WindowStartupLocation.CenterScreen\r\n        self.Background = bg_color\r\n        self.ResizeMode = 0\r\n\r\n        panel = StackPanel()\r\n        panel.Margin = Thickness(20)\r\n\r\n        scroll = ScrollViewer()\r\n        scroll.VerticalScrollBarVisibility = 0\r\n        scroll.HorizontalScrollBarVisibility = 0\r\n\r\n        txt = TextBlock()\r\n        txt.Text = message\r\n        txt.FontSize = 16\r\n        txt.TextWrapping = System.Windows.TextWrapping.Wrap\r\n        txt.TextAlignment = System.Windows.TextAlignment.Center\r\n        txt.FontWeight = FontWeights.SemiBold\r\n        txt.Foreground = Brushes.White\r\n        txt.HorizontalAlignment = HorizontalAlignment.Center\r\n\r\n        scroll.Content = txt\r\n\r\n        btn = Button()\r\n        btn.Content = \"OK\"\r\n        btn.Width = 90\r\n        btn.Height = 36\r\n        btn.HorizontalAlignment = HorizontalAlignment.Center\r\n        btn.Margin = Thickness(0, 16, 0, 0)\r\n        btn.Background = Brushes.White\r\n        btn.Foreground = bg_color\r\n        btn.FontWeight = FontWeights.Bold\r\n        btn.Click += self.close_window\r\n\r\n        panel.Children.Add(scroll)\r\n        panel.Children.Add(btn)\r\n        self.Content = panel\r\n\r\n    def close_window(self, sender, args):\r\n        self.Close()\r\n\r\n# -------------------------------\r\n# MESSAGE + COLOR LOGIC\r\n# -------------------------------\r\nif is_already_placed:\r\n    # SCENARIO A: Dampers were already present\r\n    if warning_count == 0:\r\n        message = \"No new Fire damper needed.\\nAll required dampers are already placed.\"\r\n        bg_color = Brushes.SeaGreen\r\n    else:\r\n        message = (\r\n            \"No new Fire damper needed.\\n\"\r\n            \"However, there are {} warnings.\\n\"\r\n            \"Open 'Warning' Tool from MDP to check the issues.\"\r\n        ).format(warning_count)\r\n        bg_color = Brushes.Goldenrod\r\nelse:\r\n    # SCENARIO B: Normal processing\r\n    if damper_count == 0:\r\n        message = \"No Fire damper placed\\nCheck the inputs again\"\r\n        bg_color = Brushes.IndianRed\r\n    else:\r\n        if warning_count == 0:\r\n            message = (\r\n                \"Total Fire damper placed : {}\\n\"\r\n                \"No warnings found\"\r\n            ).format(damper_count)\r\n            bg_color = Brushes.SeaGreen\r\n        else:\r\n            message = (\r\n                \"Total Fire damper placed : {}\\n\"\r\n                \"There are {} warnings\\n\"\r\n                \"Open 'Warning' Tool from MDP to check the issues\"\r\n            ).format(damper_count, warning_count)\r\n            bg_color = Brushes.Goldenrod\r\n\r\n# -------------------------------\r\n# SHOW POPUP\r\n# -------------------------------\r\npopup = ClashPopup(message, bg_color)\r\npopup.ShowDialog()\r\n\r\nOUT = message",
