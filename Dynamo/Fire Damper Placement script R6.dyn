    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\n\r\n# Import Dynamo ProtoGeometry for native curve manipulation\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\ninner_curves = IN[0]\r\nouter_curves = IN[1]\r\n\r\ndef project_and_trim(inner_c, outer_c):\r\n    if inner_c is None or outer_c is None:\r\n        return None\r\n        \r\n    try:\r\n        # 1. Project Outer Endpoints onto Inner Curve\r\n        # ClosestPointTo automatically stops at the ends of the inner curve (perfect for the Red/Yellow lines)\r\n        pt1 = inner_c.ClosestPointTo(outer_c.StartPoint)\r\n        pt2 = inner_c.ClosestPointTo(outer_c.EndPoint)\r\n        \r\n        # 2. Get the 0.0 to 1.0 parameters of those projected points\r\n        t1 = inner_c.ParameterAtPoint(pt1)\r\n        t2 = inner_c.ParameterAtPoint(pt2)\r\n        \r\n        # 3. Ensure we draw in the correct direction (preserves the room boundary loop direction)\r\n        t_min = min(t1, t2)\r\n        t_max = max(t1, t2)\r\n        \r\n        # If the points land on the exact same spot, it's a perpendicular miss. Skip it.\r\n        if t_max - t_min < 0.001:\r\n            return None \r\n            \r\n        # 4. Reconstruct the trimmed curve natively exactly on the inner boundary\r\n        curve_type = inner_c.__class__.__name__\r\n        \r\n        if curve_type == \"Line\":\r\n            p_start = inner_c.PointAtParameter(t_min)\r\n            p_end = inner_c.PointAtParameter(t_max)\r\n            return Line.ByStartPointEndPoint(p_start, p_end)\r\n            \r\n        elif curve_type == \"Arc\":\r\n            p_start = inner_c.PointAtParameter(t_min)\r\n            # Find the middle of the trimmed arc to ensure it curves correctly\r\n            p_mid = inner_c.PointAtParameter((t_min + t_max) / 2.0)\r\n            p_end = inner_c.PointAtParameter(t_max)\r\n            return Arc.ByThreePoints(p_start, p_mid, p_end)\r\n            \r\n        else:\r\n            # Fallback for complex splines\r\n            return inner_c\r\n            \r\n    except Exception as e:\r\n        return \"PYTHON ERROR: \" + str(e)\r\n\r\n# Recursive engine to perfectly maintain your deeply nested list structures\r\ndef process_lists(inner, outer):\r\n    if isinstance(inner, list) and isinstance(outer, list):\r\n        length = min(len(inner), len(outer))\r\n        return [process_lists(inner[i], outer[i]) for i in range(length)]\r\n    elif isinstance(inner, list):\r\n        return [process_lists(x, outer) for x in inner]\r\n    elif isinstance(outer, list):\r\n        return [process_lists(inner, x) for x in outer]\r\n    else:\r\n        return project_and_trim(inner, outer)\r\n\r\n# Run the script\r\nOUT = process_lists(inner_curves, outer_curves)",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "d9d4cf3037e64bf8a8e785ad9359641b",
      "Inputs": [
        {
          "Id": "56913ebcc3264241a074508cbf27bb67",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "fd04e49459954db08bd0c975f259b5cc",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "6f92d480f0464b1a9ca86af4b748c6f3",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
