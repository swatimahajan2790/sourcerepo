      "FunctionSignature": "DSCore.List.Flatten@var[]..[],int",
      "Id": "0b4238c32fe84c99a2482062389bcf39",
      "Inputs": [
        {
          "Id": "33fcf70707334d0497dd39454790371c",
          "Name": "list",
          "Description": "List to flatten.\n\nvar[]..[]",
          "UsingDefaultValue": false,
