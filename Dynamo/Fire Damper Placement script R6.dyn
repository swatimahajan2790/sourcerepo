    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# -*- coding: utf-8 -*-\r\n# IN[0] : List of Ducts\r\n# IN[1] : List of Points (mapped index-to-index)\r\n# IN[2] : List of Strings (mapped index-to-index)\r\n# OUT   : [flattenedDucts, flattenedSortedPoints, flattenedSortedStrings]\r\n\r\nimport clr\r\n\r\n# Revit API\r\nclr.AddReference(\"RevitAPI\")\r\nfrom Autodesk.Revit.DB import LocationCurve\r\n\r\n# Revit Services\r\nclr.AddReference(\"RevitServices\")\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\n# ProtoGeometry\r\nclr.AddReference(\"ProtoGeometry\")\r\nfrom Autodesk.DesignScript.Geometry import Point\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# -----------------------------\r\n# Helpers\r\n# -----------------------------\r\n\r\ndef to_list(obj):\r\n    if hasattr(obj, '__iter__'):\r\n        return obj\r\n    else:\r\n        return [obj]\r\n\r\ndef get_curve_parameter(curve, point):\r\n    \"\"\"\r\n    Returns normalized parameter (0–1) of point on curve.\r\n    \"\"\"\r\n    try:\r\n        result = curve.Project(point.ToXyz())\r\n        if result:\r\n            return result.Parameter\r\n        return None\r\n    except:\r\n        return None\r\n\r\n# -----------------------------\r\n# Main\r\n# -----------------------------\r\n\r\nducts = to_list(IN[0]) if IN[0] else []\r\npoints = to_list(IN[1]) if IN[1] else []\r\nstrings = to_list(IN[2]) if IN[2] else [] # NEW: Capture the string data\r\n\r\n# Ensure all three lists have the same length\r\nif len(ducts) != len(points) or len(ducts) != len(strings):\r\n    OUT = [[], [], []]\r\nelse:\r\n    ducts = [UnwrapElement(d) for d in ducts]\r\n    \r\n    # Group by duct Id\r\n    grouped = {}\r\n\r\n    for duct, pt, s_data in zip(ducts, points, strings):\r\n\r\n        if duct is None:\r\n            continue\r\n\r\n        loc = duct.Location\r\n        if not isinstance(loc, LocationCurve):\r\n            continue\r\n\r\n        curve = loc.Curve\r\n        param = get_curve_parameter(curve, pt)\r\n\r\n        if param is None:\r\n            continue\r\n\r\n        key = duct.Id.IntegerValue\r\n\r\n        if key not in grouped:\r\n            grouped[key] = {\r\n                \"duct\": duct,\r\n                \"data\": []\r\n            }\r\n\r\n        # Store the parameter, point, AND string together\r\n        grouped[key][\"data\"].append((param, pt, s_data))\r\n\r\n    # Sort inside each duct group\r\n    flat_ducts = []\r\n    flat_points = []\r\n    flat_strings = [] # NEW\r\n\r\n    for g in grouped.values():\r\n\r\n        duct = g[\"duct\"]\r\n        # Sorting by the first element (param) naturally keeps the rest of the tuple aligned\r\n        sorted_pts = sorted(g[\"data\"], key=lambda x: x[0])\r\n\r\n        for param, pt, s_data in sorted_pts:\r\n            flat_ducts.append(duct)\r\n            flat_points.append(pt)\r\n            flat_strings.append(s_data) # Append the aligned string\r\n\r\n    # Output all three parallel lists\r\n    OUT = [flat_ducts, flat_points, flat_strings]",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "b1ab911b37e44e2792a3e664c2c5c3a1",
      "Inputs": [
        {
          "Id": "0c913b843afe43a7bb87915e686994b0",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "b336c1d9a1464d7eb850c00a5a6f944b",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "2996c45673354d1eb2b6e0e9d55583bd",
          "Name": "IN[2]",
          "Description": "Input #2",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "03f509ee00344005bf0741e91be189ab",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
    {
