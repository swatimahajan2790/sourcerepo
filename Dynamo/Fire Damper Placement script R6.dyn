    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "NodeType": "CodeBlockNode",
      "Code": "true;",
      "Id": "72cfd2630e67444185206b3875cc0e80",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "a157293a239445a7b7fc3d0ce67ca353",
          "Name": "",
          "Description": "Value of expression at line 1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# -*- coding: utf-8 -*-\r\nimport clr\r\n\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript import Geometry as dg\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import XYZ, ViewPlan, ViewType, BuiltInParameter, FilteredElementCollector, Plane\r\n\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\nclr.ImportExtensions(Revit.GeometryConversion) \r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# --------------------------------------------------\r\n# Helpers\r\n# --------------------------------------------------\r\ndef is_floor_plan_view(v):\r\n    try:\r\n        if not isinstance(v, ViewPlan): return False\r\n        if v.ViewType != ViewType.FloorPlan: return False\r\n        if hasattr(v, \"IsTemplate\") and v.IsTemplate: return False\r\n        try:\r\n            dep_param = v.get_Parameter(BuiltInParameter.VIEW_DEPENDENCY)\r\n            if dep_param and dep_param.AsInteger() != 0: return False\r\n        except: pass\r\n        if not hasattr(v, \"GenLevel\") or v.GenLevel is None: return False\r\n        return True\r\n    except: return False\r\n\r\ndef bbox_intersects_dynamo(bb_elem, bb_level, tol=0.0):\r\n    \"\"\"Checks if two Dynamo bounding boxes intersect in 3D space.\"\"\"\r\n    if bb_elem is None or bb_level is None: return False\r\n    \r\n    e_min, e_max = bb_elem.MinPoint, bb_elem.MaxPoint\r\n    l_min, l_max = bb_level.MinPoint, bb_level.MaxPoint\r\n    \r\n    if (e_max.X + tol < l_min.X) or (e_min.X - tol > l_max.X): return False\r\n    if (e_max.Y + tol < l_min.Y) or (e_min.Y - tol > l_max.Y): return False\r\n    if (e_max.Z + tol < l_min.Z) or (e_min.Z - tol > l_max.Z): return False\r\n    \r\n    return True\r\n\r\ndef flatten_parallel(items, coords):\r\n    \"\"\"Recursively flattens nested lists while keeping Elements and CoordinateSystems paired.\"\"\"\r\n    flat_items = []\r\n    flat_coords = []\r\n    \r\n    if isinstance(items, (list, tuple)):\r\n        # Ensure coords is also a list for safe indexing\r\n        c_list = coords if isinstance(coords, (list, tuple)) else [coords] * len(items)\r\n        \r\n        for i in range(len(items)):\r\n            c_item = c_list[i] if i < len(c_list) else None\r\n            sub_items, sub_coords = flatten_parallel(items[i], c_item)\r\n            flat_items.extend(sub_items)\r\n            flat_coords.extend(sub_coords)\r\n        return flat_items, flat_coords\r\n    else:\r\n        return [items], [coords]\r\n\r\n# --------------------------------------------------\r\n# Main\r\n# --------------------------------------------------\r\n\r\nraw_elements = UnwrapElement(IN[0])\r\nraw_coords = UnwrapElement(IN[1])\r\n\r\n# Flatten the nested lists in perfect synchronization\r\nflat_elements, flat_coords = flatten_parallel(raw_elements, raw_coords)\r\n\r\n# --------------------------------------------------\r\n# STEP 1: Get Element BBXs and Transform\r\n# --------------------------------------------------\r\n\r\ndynamo_element_bboxes = []\r\n\r\nfor e, cs in zip(flat_elements, flat_coords):\r\n    if e is None: \r\n        dynamo_element_bboxes.append(None)\r\n        continue\r\n    try:\r\n        bb = e.get_BoundingBox(None)\r\n        if bb is None: \r\n            dynamo_element_bboxes.append(None)\r\n            continue\r\n\r\n        dyn_bb = bb.ToProtoType()\r\n\r\n        if cs is not None and isinstance(cs, dg.CoordinateSystem):\r\n            p_min = dyn_bb.MinPoint\r\n            p_max = dyn_bb.MaxPoint\r\n            \r\n            corners = [\r\n                dg.Point.ByCoordinates(p_min.X, p_min.Y, p_min.Z),\r\n                dg.Point.ByCoordinates(p_min.X, p_min.Y, p_max.Z),\r\n                dg.Point.ByCoordinates(p_min.X, p_max.Y, p_min.Z),\r\n                dg.Point.ByCoordinates(p_min.X, p_max.Y, p_max.Z),\r\n                dg.Point.ByCoordinates(p_max.X, p_min.Y, p_min.Z),\r\n                dg.Point.ByCoordinates(p_max.X, p_min.Y, p_max.Z),\r\n                dg.Point.ByCoordinates(p_max.X, p_max.Y, p_min.Z),\r\n                dg.Point.ByCoordinates(p_max.X, p_max.Y, p_max.Z)\r\n            ]\r\n            \r\n            transformed_pts = [pt.Transform(cs) for pt in corners]\r\n            \r\n            tx = [p.X for p in transformed_pts]\r\n            ty = [p.Y for p in transformed_pts]\r\n            tz = [p.Z for p in transformed_pts]\r\n            \r\n            pmin_new = dg.Point.ByCoordinates(min(tx), min(ty), min(tz))\r\n            pmax_new = dg.Point.ByCoordinates(max(tx), max(ty), max(tz))\r\n            dynamo_element_bboxes.append(dg.BoundingBox.ByCorners(pmin_new, pmax_new))\r\n        else:\r\n            dynamo_element_bboxes.append(dyn_bb)\r\n            \r\n    except:\r\n        dynamo_element_bboxes.append(None)\r\n\r\n# --------------------------------------------------\r\n# STEP 2: Create GLOBAL X/Y Limits\r\n# --------------------------------------------------\r\n\r\ndyn_xs, dyn_ys = [], []\r\n\r\nfor dbb in dynamo_element_bboxes:\r\n    if dbb is None: continue\r\n    dyn_xs.extend([dbb.MinPoint.X, dbb.MaxPoint.X])\r\n    dyn_ys.extend([dbb.MinPoint.Y, dbb.MaxPoint.Y])\r\n\r\nif not dyn_xs:\r\n    OUT = [[], [], [], \"No valid elements found\"]\r\nelse:\r\n    globalMinX = min(dyn_xs)\r\n    globalMaxX = max(dyn_xs)\r\n    globalMinY = min(dyn_ys)\r\n    globalMaxY = max(dyn_ys)\r\n\r\n    # --------------------------------------------------\r\n    # STEP 3: Collect Floor Plan Levels\r\n    # --------------------------------------------------\r\n    all_viewplans = FilteredElementCollector(doc).OfClass(ViewPlan).ToElements()\r\n    floor_plans = [v for v in all_viewplans if is_floor_plan_view(v)]\r\n\r\n    level_dict = {}\r\n    for vp in floor_plans:\r\n        try:\r\n            if vp.GenLevel:\r\n                level_dict[vp.GenLevel.Id] = vp.GenLevel\r\n        except: pass\r\n\r\n    levels = list(level_dict.values())\r\n    levels.sort(key=lambda l: l.Elevation)\r\n\r\n    # --------------------------------------------------\r\n    # STEP 4: Build Level Bounding Boxes (UPDATED GAP LOGIC)\r\n    # --------------------------------------------------\r\n    level_bboxes = []\r\n    \r\n    gap_mm = 20.0 # Creates a 20mm dead zone above and below floors\r\n    default_height_mm = 6000.0\r\n\r\n    for i, lvl in enumerate(levels):\r\n        try: elev = lvl.ProjectElevation\r\n        except: elev = lvl.Elevation \r\n            \r\n        pt_xyz = XYZ(0, 0, elev)\r\n        dyn_plane = Plane.CreateByNormalAndOrigin(XYZ.BasisZ, pt_xyz).ToPlane()\r\n        base_z_mm = dyn_plane.Origin.Z\r\n\r\n        # Add the gap to push the bounding box UP from the slab\r\n        zBottom_mm = base_z_mm + gap_mm\r\n        \r\n        if i < len(levels) - 1:\r\n            try: next_elev = levels[i+1].ProjectElevation\r\n            except: next_elev = levels[i+1].Elevation\r\n                \r\n            next_pt = XYZ(0, 0, next_elev)\r\n            next_z_mm = Plane.CreateByNormalAndOrigin(XYZ.BasisZ, next_pt).ToPlane().Origin.Z\r\n            \r\n            # Subtract the gap to pull the bounding box DOWN from the next slab\r\n            zTop_mm = next_z_mm - gap_mm\r\n        else:\r\n            # If it's the top level, apply the default height and still subtract the gap\r\n            zTop_mm = base_z_mm + default_height_mm - gap_mm\r\n\r\n        pmin_lvl = dg.Point.ByCoordinates(globalMinX, globalMinY, zBottom_mm)\r\n        pmax_lvl = dg.Point.ByCoordinates(globalMaxX, globalMaxY, zTop_mm)\r\n        \r\n        lvl_bbx = dg.BoundingBox.ByCorners(pmin_lvl, pmax_lvl)\r\n        level_bboxes.append(lvl_bbx)\r\n\r\n    # --------------------------------------------------\r\n    # STEP 5: Group Elements & Transforms Per Level\r\n    # --------------------------------------------------\r\n    elements_per_level = []\r\n    coords_per_level = []  \r\n    tol_mm = 1.0 \r\n\r\n    for lvbb in level_bboxes:\r\n        lvl_elems = []\r\n        lvl_coords = []    \r\n        \r\n        for e, ebb, cs in zip(flat_elements, dynamo_element_bboxes, flat_coords):\r\n            if ebb is None: continue\r\n            \r\n            if bbox_intersects_dynamo(ebb, lvbb, tol=tol_mm):\r\n                lvl_elems.append(e)\r\n                lvl_coords.append(cs) \r\n                \r\n        elements_per_level.append(lvl_elems)\r\n        coords_per_level.append(lvl_coords) \r\n\r\n    # STRUCTURED OUTPUT:\r\n    OUT = [levels, elements_per_level, coords_per_level, level_bboxes]",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "c7d790c9fa0d493788fa7161807ceae1",
      "Inputs": [
        {
          "Id": "2fa9b9fd790a44ddac7c13d96619b344",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "69bdc1c000a547e7944e061b5bee8c0a",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "52faa60859d24c1db4b6309f11639ce8",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "NodeType": "CodeBlockNode",
      "Code": "levels_[0];\nelements_[1];",
      "Id": "28fc27c0aa3b4379987295ef152248a7",
