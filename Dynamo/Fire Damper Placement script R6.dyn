    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Dynamo Python Node\r\n# IN[0] -> Boolean (True/False) or list of booleans\r\n# IN[1] -> Value if True (scalar, list, nested)\r\n# IN[2] -> Value if False (scalar, list, nested)\r\n# OUT   -> Selected value (scalar or list)\r\n\r\ncondition = IN[0]\r\ntrue_val  = IN[1]\r\nfalse_val = IN[2]\r\n\r\ndef pick_for_index(container, idx):\r\n    \"\"\"Return container[idx] if container is a list-like and idx exists,\r\n       otherwise return container itself (scalar or nested).\"\"\"\r\n    if isinstance(container, list):\r\n        if idx < len(container):\r\n            return container[idx]\r\n        # index out of range -> fallback to whole container\r\n    return container\r\n\r\ndef select_by_condition(cond, tval, fval):\r\n    \"\"\"If cond is a list of booleans, return a list of selections.\r\n       If cond is a single boolean, return the corresponding value directly.\"\"\"\r\n    # Case: list of booleans -> produce list output\r\n    if isinstance(cond, list):\r\n        out = []\r\n        for i, c in enumerate(cond):\r\n            tv = pick_for_index(tval, i)\r\n            fv = pick_for_index(fval, i)\r\n            out.append(tv if c else fv)\r\n        return out\r\n    # Case: single boolean -> return whole tval or fval (preserve structure)\r\n    return tval if cond else fval\r\n\r\nOUT = select_by_condition(condition, true_val, false_val)\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "8a14b2c54ea4415b94427c803920535c",
      "Inputs": [
        {
          "Id": "86fda9ee3b29403a9cdfea61a2060492",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "b7c6c12183a2460a809e4f82be53625d",
          "Name": "IN[1]",
