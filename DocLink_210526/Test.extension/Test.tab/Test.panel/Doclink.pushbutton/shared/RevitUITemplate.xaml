    <!-- ── Style.Button.Toolbar (DocLink dark toolbar buttons — white text, transparent bg) ── -->
    <Style x:Key="Style.Button.Toolbar" TargetType="Button">
        <Setter Property="Height"           Value="{StaticResource Height.Button.Standard}"/>
        <Setter Property="Padding"          Value="{StaticResource Padding.Button.Toolbar}"/>
        <Setter Property="Margin"           Value="{StaticResource Margin.Button.Toolbar}"/>
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderBrush"      Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Foreground"       Value="{StaticResource Brush.Text.OnDark}"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="FontWeight"       Value="SemiBold"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Standard}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter x:Name="Content"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Toolbar.Button.Hover}"/>
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{StaticResource Brush.Border.Subtle}"/>
                            <Setter TargetName="Root" Property="BorderThickness" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Accent.PrimaryPressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Content" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.Button.Icon (small icon-only button, square) ── -->
    <Style x:Key="Style.Button.Icon" TargetType="Button"
           BasedOn="{StaticResource Style.Button.Secondary}">
        <Setter Property="Width"    Value="{StaticResource Height.Button.Standard}"/>
        <Setter Property="Height"   Value="{StaticResource Height.Button.Standard}"/>
        <Setter Property="Padding"  Value="{StaticResource Padding.Button.Icon}"/>
    </Style>

    <!-- ── Style.Button.Compact (24px height for tight UIs) ── -->
    <Style x:Key="Style.Button.Compact" TargetType="Button"
           BasedOn="{StaticResource Style.Button.Secondary}">
        <Setter Property="Height"   Value="{StaticResource Height.Button.Compact}"/>
        <Setter Property="Padding"  Value="{StaticResource Padding.Button.Compact}"/>
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Small}"/>
    </Style>

    <!-- ── Style.Button.Dark.Primary (GeometryControl — dark theme primary) ── -->
    <Style x:Key="Style.Button.Dark.Primary" TargetType="Button">
        <Setter Property="Height"           Value="{StaticResource Height.Button.Standard}"/>
        <Setter Property="Padding"          Value="{StaticResource Padding.Button.Standard}"/>
        <Setter Property="Background"       Value="{StaticResource Dark.Brush.Accent.Primary}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource Dark.Brush.Accent.PrimaryHover}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Foreground"       Value="{StaticResource Dark.Brush.Text.OnAccent}"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="FontWeight"       Value="SemiBold"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Standard}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Dark.Brush.Accent.PrimaryHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Dark.Brush.Accent.PrimaryPressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.Button.Dark.Secondary (GeometryControl secondary) ── -->
    <Style x:Key="Style.Button.Dark.Secondary" TargetType="Button">
        <Setter Property="Height"           Value="{StaticResource Height.Button.Standard}"/>
        <Setter Property="Padding"          Value="{StaticResource Padding.Button.Standard}"/>
        <Setter Property="Background"       Value="{StaticResource Dark.Brush.Button.Default}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource Dark.Brush.Border.Default}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Foreground"       Value="{StaticResource Dark.Brush.Text.Primary}"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Standard}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Dark.Brush.Button.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Dark.Brush.Button.Pressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ══════════════════════════════════════════════════════════════════════════
         §7  INPUT STYLES
    ══════════════════════════════════════════════════════════════════════════ -->

    <!-- ── Style.TextBox.Standard ── -->
    <Style x:Key="Style.TextBox.Standard" TargetType="TextBox">
        <Setter Property="Height"               Value="{StaticResource Height.Input}"/>
        <Setter Property="Padding"              Value="{StaticResource Padding.Input}"/>
        <Setter Property="Background"           Value="{StaticResource Brush.Input.Background}"/>
        <Setter Property="BorderBrush"          Value="{StaticResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="Foreground"           Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontFamily"           Value="Segoe UI"/>
        <Setter Property="FontSize"             Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SelectionBrush"       Value="{StaticResource Brush.Selection.Background}"/>
        <Setter Property="CaretBrush"           Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="UseLayoutRounding"    Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Small}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="0"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{StaticResource Brush.Accent.Primary}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{StaticResource Brush.Border.Focus}"/>
                            <Setter TargetName="Root" Property="BorderThickness"
                                    Value="{StaticResource BorderThickness.Focus}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Input.Disabled}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource Brush.Text.Disabled}"/>
                        </Trigger>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Panel.Secondary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.TextBox.Search (with search icon visual hint, slightly taller) ── -->
    <Style x:Key="Style.TextBox.Search" TargetType="TextBox"
           BasedOn="{StaticResource Style.TextBox.Standard}">
        <Setter Property="Height"   Value="{StaticResource Height.Input.Large}"/>
        <Setter Property="Padding"  Value="24,2,6,2"/>
    </Style>

    <!-- ── Style.TextBox.Dark ── -->
    <Style x:Key="Style.TextBox.Dark" TargetType="TextBox"
           BasedOn="{StaticResource Style.TextBox.Standard}">
        <Setter Property="Background"   Value="{StaticResource Dark.Brush.Input.Background}"/>
        <Setter Property="BorderBrush"  Value="{StaticResource Dark.Brush.Border.Default}"/>
        <Setter Property="Foreground"   Value="{StaticResource Dark.Brush.Text.Primary}"/>
        <Setter Property="CaretBrush"   Value="{StaticResource Dark.Brush.Text.Primary}"/>
    </Style>

    <!-- ── Style.ComboBox.Standard ── -->
    <Style x:Key="Style.ComboBox.Standard" TargetType="ComboBox">
        <Setter Property="Height"               Value="{StaticResource Height.Input}"/>
        <Setter Property="Padding"              Value="{StaticResource Padding.Input}"/>
        <Setter Property="Background"           Value="{StaticResource Brush.Input.Background}"/>
        <Setter Property="BorderBrush"          Value="{StaticResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="Foreground"           Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontFamily"           Value="Segoe UI"/>
        <Setter Property="FontSize"             Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="UseLayoutRounding"    Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="Root"
                                Grid.ColumnSpan="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource Radius.Small}"
                                SnapsToDevicePixels="True"/>
                        <ContentPresenter x:Name="ContentSite"
                                          Grid.Column="0"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          IsHitTestVisible="False"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          HorizontalAlignment="Left"/>
                        <Path x:Name="Arrow"
                              Grid.Column="1"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M0,0 L4,4 L8,0 Z"
                              Fill="{StaticResource Brush.Text.Secondary}"
                              IsHitTestVisible="False"
                              Margin="0,0,2,0"/>
                        <ToggleButton Grid.ColumnSpan="2"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand"/>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               PopupAnimation="Slide"
                               Placement="Bottom">
                            <Border x:Name="DropBorder"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{StaticResource Brush.Panel.Background}"
                                    BorderBrush="{StaticResource Brush.Border.Default}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Small}"
                                    Effect="{DynamicResource {x:Static SystemParameters.DropShadowKey}}">
                                <ScrollViewer SnapsToDevicePixels="True"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{StaticResource Brush.Accent.Primary}"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{StaticResource Brush.Border.Focus}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Input.Disabled}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource Brush.Text.Disabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Resources>
            <Style TargetType="ComboBoxItem">
                <Setter Property="Padding"      Value="8,5,8,5"/>
                <Setter Property="FontFamily"   Value="Segoe UI"/>
                <Setter Property="FontSize"     Value="{StaticResource Font.Size.Standard}"/>
                <Setter Property="Foreground"   Value="{StaticResource Brush.Text.Primary}"/>
                <Setter Property="Background"   Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="ItemRoot"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemRoot" Property="Background"
                                            Value="{StaticResource Brush.DataGrid.RowHover}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemRoot" Property="Background"
                                            Value="{StaticResource Brush.Selection.Background}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Style.Resources>
    </Style>

    <!-- ── Style.CheckBox.Standard ── -->
    <Style x:Key="Style.CheckBox.Standard" TargetType="CheckBox">
        <Setter Property="FontFamily"   Value="Segoe UI"/>
        <Setter Property="FontSize"     Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="Foreground"   Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border x:Name="Box"
                                Width="14" Height="14"
                                Background="{StaticResource Brush.Input.Background}"
                                BorderBrush="{StaticResource Brush.Border.Default}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Small}"
                                SnapsToDevicePixels="True"
                                Margin="0,0,5,0">
                            <Path x:Name="Check"
                                  Width="10" Height="8"
                                  Data="M1,4 L4,7 L9,1"
                                  Stroke="{StaticResource Brush.Text.OnAccent}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="Collapsed"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box"   Property="Background"
                                    Value="{StaticResource Brush.Accent.Primary}"/>
                            <Setter TargetName="Box"   Property="BorderBrush"
                                    Value="{StaticResource Brush.Accent.PrimaryHover}"/>
                            <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box"   Property="Background"
                                    Value="{StaticResource Brush.Panel.Secondary}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush"
                                    Value="{StaticResource Brush.Accent.Primary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Box" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.RadioButton.Standard ── -->
    <Style x:Key="Style.RadioButton.Standard" TargetType="RadioButton">
        <Setter Property="FontFamily"   Value="Segoe UI"/>
        <Setter Property="FontSize"     Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="Foreground"   Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border x:Name="Outer"
                                Width="14" Height="14"
                                Background="{StaticResource Brush.Input.Background}"
                                BorderBrush="{StaticResource Brush.Border.Default}"
                                BorderThickness="1"
                                CornerRadius="7"
                                SnapsToDevicePixels="True"
                                Margin="0,0,5,0">
                            <Ellipse x:Name="Dot"
                                     Width="6" Height="6"
                                     Fill="{StaticResource Brush.Text.OnAccent}"
                                     Visibility="Collapsed"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Outer" Property="Background"
                                    Value="{StaticResource Brush.Accent.Primary}"/>
                            <Setter TargetName="Outer" Property="BorderBrush"
                                    Value="{StaticResource Brush.Accent.PrimaryHover}"/>
                            <Setter TargetName="Dot"   Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="BorderBrush"
                                    Value="{StaticResource Brush.Accent.Primary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Outer" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ══════════════════════════════════════════════════════════════════════════
         §8  LISTBOX STYLES
    ══════════════════════════════════════════════════════════════════════════ -->

    <!-- ── Style.ListBoxItem.Standard ── -->
    <Style x:Key="Style.ListBoxItem.Standard" TargetType="ListBoxItem">
        <Setter Property="Padding"      Value="8,5,8,5"/>
        <Setter Property="FontFamily"   Value="Segoe UI"/>
        <Setter Property="FontSize"     Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="Foreground"   Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.DataGrid.RowHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Selection.Background}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected"    Value="True"/>
                                <Condition Property="IsMouseOver"   Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Accent.PrimaryHover}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource Brush.Text.OnAccent}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.ListBox.Standard ── -->
    <Style x:Key="Style.ListBox.Standard" TargetType="ListBox">
        <Setter Property="Background"       Value="{StaticResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="Foreground"       Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="Padding"          Value="0"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource Style.ListBoxItem.Standard}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Small}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer Focusable="False"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}">
                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.ListBox.Extended (multi-select, same visual as Standard) ── -->
    <Style x:Key="Style.ListBox.Extended" TargetType="ListBox"
           BasedOn="{StaticResource Style.ListBox.Standard}">
        <Setter Property="SelectionMode" Value="Extended"/>
    </Style>

    <!-- ── Style.ListBoxItem.Dark ── -->
    <Style x:Key="Style.ListBoxItem.Dark" TargetType="ListBoxItem"
           BasedOn="{StaticResource Style.ListBoxItem.Standard}">
        <Setter Property="Foreground" Value="{StaticResource Dark.Brush.Text.Primary}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Dark.Brush.DataGrid.RowHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Dark.Brush.Selection.Background}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.ListBox.Dark ── -->
    <Style x:Key="Style.ListBox.Dark" TargetType="ListBox"
           BasedOn="{StaticResource Style.ListBox.Standard}">
        <Setter Property="Background"   Value="{StaticResource Dark.Brush.Panel.Background}"/>
        <Setter Property="BorderBrush"  Value="{StaticResource Dark.Brush.Border.Default}"/>
        <Setter Property="Foreground"   Value="{StaticResource Dark.Brush.Text.Primary}"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource Style.ListBoxItem.Dark}"/>
    </Style>

    <!-- ── Style.ListBox.Dark.Extended ── -->
    <Style x:Key="Style.ListBox.Dark.Extended" TargetType="ListBox"
           BasedOn="{StaticResource Style.ListBox.Dark}">
        <Setter Property="SelectionMode" Value="Extended"/>
    </Style>


    <!-- ══════════════════════════════════════════════════════════════════════════
         §9  TAB STYLES
    ══════════════════════════════════════════════════════════════════════════ -->

    <!-- ── Style.TabItem.Standard ── -->
    <Style x:Key="Style.TabItem.Standard" TargetType="TabItem">
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="Foreground"       Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="Background"       Value="{StaticResource Brush.Tab.Unselected}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource Brush.Border.Default}"/>
        <Setter Property="Padding"          Value="12,0,12,0"/>
        <Setter Property="Height"           Value="{StaticResource Height.TabItem}"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{StaticResource BorderThickness.Tab.Selected}"
                            CornerRadius="3,3,0,0"
                            Margin="0,0,2,0"
                            SnapsToDevicePixels="True">
                        <ContentPresenter x:Name="Content"
                                          ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Tab.Selected}"/>
                            <Setter TargetName="Root" Property="Margin" Value="0,0,2,-1"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Tab.Hover}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected"  Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Tab.Selected}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.TabItem.Tinted.Blue (D-Sync Tab 1) ── -->
    <Style x:Key="Style.TabItem.Tinted.Blue" TargetType="TabItem"
           BasedOn="{StaticResource Style.TabItem.Standard}">
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Tab.Tint.Blue}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Style.TabItem.Tinted.Green (D-Sync Tab 2) ── -->
    <Style x:Key="Style.TabItem.Tinted.Green" TargetType="TabItem"
           BasedOn="{StaticResource Style.TabItem.Standard}">
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Tab.Tint.Green}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Style.TabControl.Standard ── -->
    <Style x:Key="Style.TabControl.Standard" TargetType="TabControl">
        <Setter Property="Background"       Value="{StaticResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="Padding"          Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="{StaticResource Brush.Panel.Elevated}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TabPanel IsItemsHost="True"
                                      Margin="4,4,4,0"
                                      Background="Transparent"/>
                        </Border>
                        <Border Grid.Row="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,0">
                            <ContentPresenter ContentSource="SelectedContent"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.TabItem.Dark (GeometryControl) ── -->
    <Style x:Key="Style.TabItem.Dark" TargetType="TabItem">
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="Foreground"       Value="{StaticResource Dark.Brush.Text.Secondary}"/>
        <Setter Property="Background"       Value="{StaticResource Dark.Brush.Tab.Unselected}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource Dark.Brush.Border.Default}"/>
        <Setter Property="Padding"          Value="12,0,12,0"/>
        <Setter Property="Height"           Value="{StaticResource Height.TabItem}"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="3"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border x:Name="AccentStripe"
                                Grid.Row="0"
                                Background="Transparent"
                                CornerRadius="2,2,0,0"/>
                        <Border x:Name="Root"
                                Grid.Row="1"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="Content"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Dark.Brush.Tab.Selected}"/>
                            <Setter TargetName="AccentStripe" Property="Background"
                                    Value="{StaticResource Dark.Brush.Accent.Primary}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource Dark.Brush.Text.Primary}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Dark.Brush.Tab.Hover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.TabControl.Dark ── -->
    <Style x:Key="Style.TabControl.Dark" TargetType="TabControl">
        <Setter Property="Background"       Value="{StaticResource Dark.Brush.Panel.Background}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource Dark.Brush.Border.Default}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Padding"          Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="{StaticResource Dark.Brush.Panel.Secondary}"
                                BorderBrush="{StaticResource Dark.Brush.Border.Default}"
                                BorderThickness="0,0,0,1">
                            <TabPanel IsItemsHost="True"
                                      Margin="4,2,4,0"
                                      Background="Transparent"/>
                        </Border>
                        <Border Grid.Row="1"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter ContentSource="SelectedContent"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ══════════════════════════════════════════════════════════════════════════
         §10  DATAGRID STYLES
    ══════════════════════════════════════════════════════════════════════════ -->

    <!-- ── Style.DataGridColumnHeader.Standard ── -->
    <Style x:Key="Style.DataGridColumnHeader.Standard" TargetType="DataGridColumnHeader">
        <Setter Property="Background"       Value="{StaticResource Brush.DataGrid.Header}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource Brush.DataGrid.HeaderBorder}"/>
        <Setter Property="BorderThickness"  Value="0,0,1,1"/>
        <Setter Property="Foreground"       Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="FontWeight"       Value="SemiBold"/>
        <Setter Property="Padding"          Value="8,6,8,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="SeparatorBrush"   Value="{StaticResource Brush.DataGrid.HeaderBorder}"/>
        <Setter Property="SeparatorVisibility" Value="Visible"/>
    </Style>

    <!-- ── Style.DataGridRow.Standard ── -->
    <Style x:Key="Style.DataGridRow.Standard" TargetType="DataGridRow">
        <Setter Property="Background"           Value="{StaticResource Brush.DataGrid.Background}"/>
        <Setter Property="BorderBrush"          Value="{StaticResource Brush.DataGrid.GridLine}"/>
        <Setter Property="FontFamily"           Value="Segoe UI"/>
        <Setter Property="FontSize"             Value="{StaticResource Font.Size.DataGrid}"/>
        <Setter Property="Foreground"           Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="MinHeight"            Value="{StaticResource Height.DataGridRow}"/>
        <Setter Property="UseLayoutRounding"    Value="True"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background"
                        Value="{StaticResource Brush.DataGrid.RowHover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background"
                        Value="{StaticResource Brush.DataGrid.RowSelected}"/>
            </Trigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self},
                         Path=(ItemsControl.AlternationIndex)}" Value="1">
                <Setter Property="Background"
                        Value="{StaticResource Brush.DataGrid.AltRow}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ── Style.DataGridCell.Standard ── -->
    <Style x:Key="Style.DataGridCell.Standard" TargetType="DataGridCell">
        <Setter Property="Padding"          Value="{StaticResource Padding.Cell}"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="{StaticResource Font.Size.DataGrid}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border x:Name="Root"
                            Background="Transparent"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground"
                                    Value="{StaticResource Brush.Text.Primary}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{StaticResource Brush.Border.Focus}"/>
                            <Setter TargetName="Root" Property="BorderThickness" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.DataGrid.Standard ── -->
    <Style x:Key="Style.DataGrid.Standard" TargetType="DataGrid">
        <Setter Property="Background"               Value="{StaticResource Brush.DataGrid.Background}"/>
        <Setter Property="BorderBrush"              Value="{StaticResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="Foreground"               Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontFamily"               Value="Segoe UI"/>
        <Setter Property="FontSize"                 Value="{StaticResource Font.Size.DataGrid}"/>
        <Setter Property="RowHeight"                Value="{StaticResource Height.DataGridRow}"/>
        <Setter Property="AlternationCount"         Value="2"/>
        <Setter Property="AutoGenerateColumns"      Value="False"/>
        <Setter Property="CanUserAddRows"           Value="False"/>
        <Setter Property="CanUserDeleteRows"        Value="False"/>
        <Setter Property="SelectionMode"            Value="Single"/>
        <Setter Property="SelectionUnit"            Value="FullRow"/>
        <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Brush.DataGrid.GridLine}"/>
        <Setter Property="VerticalGridLinesBrush"   Value="{StaticResource Brush.DataGrid.GridLine}"/>
        <Setter Property="HeadersVisibility"        Value="Column"/>
        <Setter Property="RowHeaderWidth"           Value="0"/>
        <Setter Property="UseLayoutRounding"        Value="True"/>
        <Setter Property="ColumnHeaderStyle"        Value="{StaticResource Style.DataGridColumnHeader.Standard}"/>
        <Setter Property="RowStyle"                 Value="{StaticResource Style.DataGridRow.Standard}"/>
        <Setter Property="CellStyle"                Value="{StaticResource Style.DataGridCell.Standard}"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="ScrollViewer.PanningMode"      Value="Both"/>
    </Style>


    <!-- ══════════════════════════════════════════════════════════════════════════
         §11  OVERLAY &amp; COMPOUND CONTROLS
    ══════════════════════════════════════════════════════════════════════════ -->

    <!-- ── Style.ProgressBar.Standard ── -->
    <Style x:Key="Style.ProgressBar.Standard" TargetType="ProgressBar">
        <Setter Property="Height"       Value="8"/>
        <Setter Property="Background"   Value="{StaticResource Brush.Panel.Elevated}"/>
        <Setter Property="BorderBrush"  Value="{StaticResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground"   Value="{StaticResource Brush.Accent.Primary}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Small}"
                            ClipToBounds="True">
                        <Border x:Name="PART_Indicator"
                                HorizontalAlignment="Left"
                                Background="{TemplateBinding Foreground}"
                                CornerRadius="{StaticResource Radius.Small}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.ToolTip.Standard ── -->
    <Style x:Key="Style.ToolTip.Standard" TargetType="ToolTip">
        <Setter Property="Background"       Value="{StaticResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Foreground"       Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="Padding"          Value="8,4,8,4"/>
        <Setter Property="HasDropShadow"    Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Small}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.MenuItem.Standard ── -->
    <Style x:Key="Style.MenuItem.Standard" TargetType="MenuItem">
        <Setter Property="FontFamily"   Value="Segoe UI"/>
        <Setter Property="FontSize"     Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="Foreground"   Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="Padding"      Value="8,5,16,5"/>
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal">
                            <ContentPresenter ContentSource="Icon"
                                              Width="16" Height="16"
                                              Margin="0,0,6,0"
                                              VerticalAlignment="Center"/>
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.DataGrid.RowHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{StaticResource Brush.Text.Disabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.ContextMenu.Standard ── -->
    <Style x:Key="Style.ContextMenu.Standard" TargetType="ContextMenu">
        <Setter Property="Background"       Value="{StaticResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Padding"          Value="0,4,0,4"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="HasDropShadow"    Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Small}"
                            Padding="{TemplateBinding Padding}">
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.GroupBox.Standard ── -->
    <Style x:Key="Style.GroupBox.Standard" TargetType="GroupBox">
        <Setter Property="BorderBrush"      Value="{StaticResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Foreground"       Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="FontWeight"       Value="SemiBold"/>
        <Setter Property="Padding"          Value="8,6,8,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.RowSpan="2"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource Radius.Standard}"
                                Margin="0,8,0,0"/>
                        <Border Grid.Row="0"
                                HorizontalAlignment="Left"
                                Margin="10,0,0,0"
                                Padding="4,0,4,0"
                                Background="{StaticResource Brush.Window.Background}">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ContentPresenter Grid.Row="1"
                                          Margin="{TemplateBinding Padding}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.Separator.Standard ── -->
    <Style x:Key="Style.Separator.Standard" TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource Brush.Border.Subtle}"/>
        <Setter Property="Height"     Value="1"/>
        <Setter Property="Margin"     Value="0,4,0,4"/>
    </Style>

