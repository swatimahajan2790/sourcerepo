    <!-- ── Style.Label.Standard ── -->
    <Style x:Key="Style.Label.Standard" TargetType="Label">
        <Setter Property="FontFamily"   Value="Segoe UI"/>
        <Setter Property="FontSize"     Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="Foreground"   Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="Padding"      Value="0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ── Style.TextBlock.Standard ── -->
    <Style x:Key="Style.TextBlock.Standard" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="Segoe UI"/>
        <Setter Property="FontSize"     Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="Foreground"   Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ── Style.TextBlock.Heading ── -->
    <Style x:Key="Style.TextBlock.Heading" TargetType="TextBlock"
           BasedOn="{StaticResource Style.TextBlock.Standard}">
        <Setter Property="FontSize"     Value="{StaticResource Font.Size.Heading}"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
    </Style>

    <!-- ── Style.TextBlock.Title ── -->
    <Style x:Key="Style.TextBlock.Title" TargetType="TextBlock"
           BasedOn="{StaticResource Style.TextBlock.Standard}">
        <Setter Property="FontSize"     Value="{StaticResource Font.Size.Title}"/>
        <Setter Property="FontWeight"   Value="Bold"/>
    </Style>

    <!-- ── Style.TextBlock.Secondary ── -->
    <Style x:Key="Style.TextBlock.Secondary" TargetType="TextBlock"
           BasedOn="{StaticResource Style.TextBlock.Standard}">
        <Setter Property="Foreground"   Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="FontSize"     Value="{StaticResource Font.Size.Small}"/>
    </Style>

    <!-- ── Style.TextBlock.Status.OK ── -->
    <Style x:Key="Style.TextBlock.Status.OK" TargetType="TextBlock"
           BasedOn="{StaticResource Style.TextBlock.Standard}">
        <Setter Property="Foreground"   Value="{StaticResource Brush.Status.OK}"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
