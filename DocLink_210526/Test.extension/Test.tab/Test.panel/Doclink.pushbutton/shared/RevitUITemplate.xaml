    <!-- ══════════════════════════════════════════════════════════════════════════
         §5  WINDOW BASE STYLE
    ══════════════════════════════════════════════════════════════════════════ -->

    <Style x:Key="Style.Window.Base" TargetType="Window">
        <Setter Property="Background"   Value="{StaticResource Brush.Window.Background}"/>
        <Setter Property="Foreground"   Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontFamily"   Value="Segoe UI"/>
        <Setter Property="FontSize"     Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="WindowStyle"  Value="SingleBorderWindow"/>
        <Setter Property="ResizeMode"   Value="CanResizeWithGrip"/>
    </Style>


    <!-- ══════════════════════════════════════════════════════════════════════════
         §6  BUTTON STYLES
    ══════════════════════════════════════════════════════════════════════════ -->

    <!-- ── Button: Base ControlTemplate (shared by all button variants) ── -->
    <ControlTemplate x:Key="Template.Button.Base" TargetType="Button">
        <Border x:Name="PART_Border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{StaticResource Radius.Standard}"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
            <ContentPresenter x:Name="PART_Content"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="{TemplateBinding Padding}"
                              RecognizesAccessKey="True"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="PART_Border" Property="Background"
                        Value="{Binding RelativeSource={RelativeSource TemplatedParent},
                               Path=Tag, Converter={x:Static BindingOperations.EmptyBinding}}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="PART_Content" Property="Opacity" Value="0.45"/>
                <Setter TargetName="PART_Border"  Property="Opacity" Value="0.75"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ── Button: Standard ControlTemplate (uses tag-less hover via Resources) ── -->
    <ControlTemplate x:Key="Template.Button.Standard" TargetType="Button">
        <Border x:Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{StaticResource Radius.Standard}"
                SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="{TemplateBinding Padding}"
                              RecognizesAccessKey="True"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Root" Property="Opacity" Value="0.5"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ── Style.Button.Secondary (default gray button — base for others) ── -->
    <Style x:Key="Style.Button.Secondary" TargetType="Button">
        <Setter Property="Height"           Value="{StaticResource Height.Button.Standard}"/>
        <Setter Property="Padding"          Value="{StaticResource Padding.Button.Standard}"/>
        <Setter Property="Background"       Value="{StaticResource Brush.Button.Default}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Foreground"       Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="{StaticResource Font.Size.Standard}"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Standard}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter x:Name="Content"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Button.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Button.Pressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Button.Disabled}"/>
                            <Setter TargetName="Content" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Style.Button.Primary (blue accent button) ── -->
    <Style x:Key="Style.Button.Primary" TargetType="Button"
           BasedOn="{StaticResource Style.Button.Secondary}">
        <Setter Property="Background"   Value="{StaticResource Brush.Accent.Primary}"/>
        <Setter Property="BorderBrush"  Value="{StaticResource Brush.Accent.PrimaryHover}"/>
        <Setter Property="Foreground"   Value="{StaticResource Brush.Text.OnAccent}"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Standard}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter x:Name="Content"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Accent.PrimaryHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Accent.PrimaryPressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource Brush.Button.Disabled}"/>
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{StaticResource Brush.Border.Default}"/>
                            <Setter TargetName="Content" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

