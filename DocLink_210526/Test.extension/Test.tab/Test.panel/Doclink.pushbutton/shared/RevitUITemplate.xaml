<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
    ═══════════════════════════════════════════════════════════════════════════════
     RevitUITemplate.xaml
     Version : 1.0.0
     Date    : 2026-04-02
     Compat  : IronPython 2.7 (pyRevit) + C# .NET 4.x WPF Revit add-ins
               Tested against Revit 2021 – 2026
     ─────────────────────────────────────────────────────────────────────────────
     SECTION MAP
       §1  File Header          (this comment)
       §2  Light Theme Brushes  (Brush.*)
       §3  Dark Theme Brushes   (Dark.Brush.*)
       §4  Sizing & Typography  (Height.*, Font.*, Padding.*, Radius.*)
       §5  Window Style         (Style.Window.Base)
       §6  Button Styles        (Style.Button.Primary/Secondary/Danger/Icon/Toolbar/Accent)
       §7  Input Styles         (Style.TextBox.*, Style.ComboBox.*, Style.CheckBox.*, Style.RadioButton.*)
       §8  ListBox Styles       (Style.ListBox.*, Style.ListBoxItem.*)
       §9  Tab Styles           (Style.TabControl.*, Style.TabItem.*)
       §10 DataGrid Styles      (Style.DataGrid.*, Style.DataGridColumnHeader.*, Style.DataGridRow.*, Style.DataGridCell.*)
       §11 Overlay Controls     (Style.ProgressBar.*, Style.ToolTip.*, Style.ContextMenu.*,
                                  Style.GroupBox.*, Style.Separator.*, Style.Border.Notification.*)
       §12 Text Styles          (Style.Label.*, Style.TextBlock.*)
     ─────────────────────────────────────────────────────────────────────────────
     USAGE — Python (IronPython / pyRevit):
       from revit_ui_loader import apply_template_to_window
       win = MyWindow()
       apply_template_to_window(win, TEMPLATE_PATH, dark=False)
       win.ShowDialog()

     USAGE — C#:
       RevitUIResources.ApplyTo(window, dark: false);
    ═══════════════════════════════════════════════════════════════════════════════
    -->


    <!-- ══════════════════════════════════════════════════════════════════════════
         §2  LIGHT THEME BRUSHES
         All style definitions reference these keys. Merging RevitUITemplate_Dark.xaml
         after this file will override these keys with dark values, making every
         style automatically dark without any style duplication.
