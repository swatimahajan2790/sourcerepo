        <Setter Property="BorderThickness"  Value="0,1,0,0"/>
        <Setter Property="MinHeight"        Value="{StaticResource Height.StatusBar}"/>
        <Setter Property="Padding"          Value="8,2,8,2"/>
    </Style>

    <!-- ── Style.Border.Toolbar.NavyBlue (DocLink Tab1 toolbar) ── -->
    <Style x:Key="Style.Border.Toolbar.NavyBlue" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource Brush.Toolbar.NavyBlue}"/>
